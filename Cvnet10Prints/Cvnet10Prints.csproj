<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- PrintEnable の既定を true にする/印刷機能を使わない場合には false に設定 -->
    <PrintEnable>true</PrintEnable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(PrintEnable)' == 'true'">
    <DefineConstants>$(DefineConstants);PRINT_ENABLE</DefineConstants>
  </PropertyGroup>

  <ItemGroup Condition="'$(PrintEnable)' == 'true'">
    <PackageReference Include="IKVM" />
  </ItemGroup>
  <ItemGroup Condition="'$(PrintEnable)' == 'true'">
    <IkvmReference Include="printstream.jar">
      <AssemblyName>printstream</AssemblyName>
      <AssemblyVersion>1.0.0.0</AssemblyVersion>
      <AssemblyFileVersion>1.0.0.0</AssemblyFileVersion>
    </IkvmReference>
  </ItemGroup>
</Project>
