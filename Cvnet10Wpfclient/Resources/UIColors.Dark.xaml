<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!--  Window Border Colors  -->
	<Color x:Key="winBorderColor1">#5C5CFF</Color>
	<Color x:Key="winBorderColor2">#8A5CFF</Color>
	<Color x:Key="winBorderColor3">#9C6BFF</Color>

	<!--  Color Palette  -->
	<SolidColorBrush x:Key="PalettePink1"
		Color="#3A2F45" />
	<SolidColorBrush x:Key="CaretColor"
		Color="#5D4B9E" />
	<SolidColorBrush x:Key="PaletteCyan"
		Color="#2C7A7B" />
	<SolidColorBrush x:Key="PalettePink2"
		Color="#B04C7B" />
	<SolidColorBrush x:Key="PalettePurple1"
		Color="#5B5E9C" />
	<SolidColorBrush x:Key="StatusTitleColor"
		Color="#C48B3A" />
	<SolidColorBrush x:Key="PalettePink3"
		Color="#9E4A66" />
	<SolidColorBrush x:Key="PaletteBlue1"
		Color="#5B7AA8" />
	<SolidColorBrush x:Key="MenuTitleColor"
		Color="#2FAF93" />
	<SolidColorBrush x:Key="PaletteSalmon"
		Color="#7A4B52" />
	<SolidColorBrush x:Key="PaletteGreen"
		Color="#3A7D3C" />
	<SolidColorBrush x:Key="PaletteBlue2"
		Color="#2B4C7E" />
	<SolidColorBrush x:Key="PaletteNavy"
		Color="#1C2E50" />

	<!--  Font Colors  -->
	<SolidColorBrush x:Key="TitleColor"
		Color="#F0F0F0" />
	<SolidColorBrush x:Key="SubTitleColor"
		Color="#E0E0E0" />
	<SolidColorBrush x:Key="plainTextColor0"
		Color="#E0E0E0" />

	<!--  Panel Colors  -->
	<SolidColorBrush x:Key="panelColor"
		Color="#2B2B2B" />
	<SolidColorBrush x:Key="panelOverColor"
		Color="#343434" />
	<SolidColorBrush x:Key="panelActiveColor"
		Color="#3F3F3F" />

	<!--  Common Background  -->
	<SolidColorBrush x:Key="AppCommonBackgroundBrush"
		Color="#1F1F1F" />

	<!--  Button Colors  -->
	<SolidColorBrush x:Key="PrimaryButtonColor"
		Color="#3D6EF7" />
</ResourceDictionary>
