<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	
	<LinearGradientBrush x:Key="SearchButtonBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
		<GradientStop Offset="0" Color="#66210F55" />
		<GradientStop Offset="1" Color="#80FB539B" />
	</LinearGradientBrush>
	<Style TargetType="{x:Type DataGridColumnHeader}">
		<Setter Property="BorderBrush">
			<Setter.Value>
				<Binding FallbackValue="Transparent"
					Path="HorizontalGridLinesBrush"
					RelativeSource="{RelativeSource AncestorType={x:Type DataGrid}}" />
			</Setter.Value>
		</Setter>
		<Setter Property="BorderThickness">
			<Setter.Value>
				<Binding FallbackValue="0,0,1,0"
					Path="GridLinesVisibility"
					RelativeSource="{RelativeSource AncestorType={x:Type DataGrid}}" />
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>
