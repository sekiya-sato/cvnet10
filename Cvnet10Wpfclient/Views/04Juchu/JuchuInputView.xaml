<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._04Juchu.JuchuInputView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:local="clr-namespace:Cvnet10Wpfclient.Views" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._04Juchu"
	Title="展示会受注入力"
	Width="1244" Height="900"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:JuchuInputViewModel />
	</helpers:BaseWindow.DataContext>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TabControl Grid.Row="0"
					d:DataContext="{d:DesignInstance Type=vm:JuchuInputViewModel, IsDesignTimeCreatable=True}"
					VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
					BorderThickness="1" 
					SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
			<TabItem Header="検索画面(Shift+F1)">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="340"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="伝票No" />
						<TextBox Grid.Row="0" Grid.Column="1"  
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.FromId}"/>
						<TextBlock Grid.Row="0" Grid.Column="2"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="0" Grid.Column="3"
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.ToId}"/>
						<Label Grid.Row="0" Grid.Column="4"   
							   VerticalContentAlignment="Center"
							   Content="受注日" />
						<DatePicker Grid.Row="0" Grid.Column="5"
									SelectedDate="{Binding SelectInputParam.FromDate, Converter={StaticResource DateConverter}}"/>
						<TextBlock Grid.Row="0" Grid.Column="6"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<DatePicker Grid.Row="0" Grid.Column="7"
									SelectedDate="{Binding SelectInputParam.ToDate, Converter={StaticResource DateConverter}}"/>
						<Label Grid.Row="0" Grid.Column="8"   
							   VerticalContentAlignment="Center"
							   Content="取引区分" />
						<ComboBox Grid.Row="0" Grid.Column="9"
								  VerticalAlignment="Top"
								  VerticalContentAlignment="Center"
								  ItemsSource="{Binding KubunItems}"
								  DisplayMemberPath="Display"
								  SelectedValuePath="Value"
								  SelectedValue="{Binding SelectInputParam.Kubun}"
								  Style="{StaticResource SearchableComboBox1}"/>
						<TextBlock Grid.Row="0" Grid.Column="10"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<ComboBox Grid.Row="0" Grid.Column="11"
								  VerticalAlignment="Top"
								  VerticalContentAlignment="Center"
								  ItemsSource="{Binding KubunItems}"
								  DisplayMemberPath="Display"
								  SelectedValuePath="Value"
								  SelectedValue="{Binding SelectInputParam.KubunTo}"
								  Style="{StaticResource SearchableComboBox1}"/>
					</Grid>

					<Grid Grid.Row="1" Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="関連No1" />
						<TextBox Grid.Row="0" Grid.Column="1"  
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.RelatedNo1From}"/>
						<TextBlock Grid.Row="0" Grid.Column="2"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="0" Grid.Column="3"
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.RelatedNo1To}"/>
						<Label Grid.Row="0" Grid.Column="4"   
							   VerticalContentAlignment="Center"
							   Content="関連No2" />
						<TextBox Grid.Row="0" Grid.Column="5"  
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.RelatedNo2From}"/>
						<TextBlock Grid.Row="0" Grid.Column="6"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="0" Grid.Column="7"  
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.RelatedNo2To}"/>
						<Label Grid.Row="0" Grid.Column="8"   
							   VerticalContentAlignment="Center"
							   Content="手入力No" />
						<TextBox Grid.Row="0" Grid.Column="9"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.ManualInputNoFrom}"/>
						<TextBlock Grid.Row="0" Grid.Column="10"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="0" Grid.Column="11"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.ManualInputNoTo}"/>
					</Grid>

					<Grid Grid.Row="2" Margin="0,0,0,5">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1.04*" />
							<ColumnDefinition Width="4*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="4*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="得意先" />
						<TextBox Grid.Row="0" Grid.Column="1"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.TokuiName}"/>
						<Button Grid.Row="0" Grid.Column="2"
											Style="{StaticResource ListButton}" 
											Command="{Binding SelectTokuiCommand}"/>
						<TextBlock Grid.Row="0" Grid.Column="3"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="0" Grid.Column="4"
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.TokuiNameTo}"/>
						<Button Grid.Row="0" Grid.Column="5"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectTokuiToCommand}"/>

						<Label Grid.Row="2" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="倉庫" />
						<TextBox Grid.Row="2" Grid.Column="1"
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.SokoName}"/>
						<Button Grid.Row="2" Grid.Column="2"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectSokoCommand}" />
						<TextBlock Grid.Row="2" Grid.Column="3"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="2" Grid.Column="4"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.SokoNameTo}"/>
						<Button Grid.Row="2" Grid.Column="5"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectSokoToCommand}" />

						<Button Grid.Row="4" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="商品"
							   Command="{Binding ToggleShohinCommand}"/>
						<TextBox Grid.Row="4" Grid.Column="1"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.ShohinName}"/>
						<Button Grid.Row="4" Grid.Column="2"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectShohinCommand}" />
						<TextBlock Grid.Row="4" Grid.Column="3"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="4" Grid.Column="4"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.ShohinNameTo}"/>
						<Button Grid.Row="4" Grid.Column="5"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectShohinToCommand}"/>

						<Label Grid.Row="6" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="展示会" />
						<TextBox Grid.Row="6" Grid.Column="1"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.TenjiName}"/>
						<Button Grid.Row="6" Grid.Column="2"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectTenjiCommand}"/>
						<TextBlock Grid.Row="6" Grid.Column="3"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="6" Grid.Column="4"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.TenjiNameTo}"/>
						<Button Grid.Row="6" Grid.Column="5"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectTenjiToCommand}"/>

						<Label Grid.Row="8" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   Content="入力者" />
						<TextBox Grid.Row="8" Grid.Column="1"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.InputUserName}"/>
						<Button Grid.Row="8" Grid.Column="2"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectInputUserCommand}"/>
						<TextBlock Grid.Row="8" Grid.Column="3"
								   Text="～"
								   Foreground="Black"
								   VerticalAlignment="Center"/>
						<TextBox Grid.Row="8" Grid.Column="4"  
								 HorizontalContentAlignment="Left"
								 VerticalContentAlignment="Center"
								 Text="{Binding SelectInputParam.InputUserNameTo}"/>
						<Button Grid.Row="8" Grid.Column="5"
											Style="{StaticResource ListButton}"
											Command="{Binding SelectInputUserToCommand}"/>
					</Grid>

					<Grid Grid.Row="3" Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition/>
							<ColumnDefinition/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
							<Button Margin="0,0,5,0" 
									HorizontalAlignment="Right" 
									BorderBrush="Black" BorderThickness="10"
									Command="{Binding PrevPageCommand}"
									Style="{DynamicResource PrevPageBtn}"/>
							<Button HorizontalAlignment="Right" 
									BorderBrush="Black" BorderThickness="10"
									Command="{Binding NextPageCommand}"
									Style="{DynamicResource NextPageBtn}" />
						</StackPanel>
						<Button Grid.Column="1" 
								Content="一覧取得(F5)" 
								HorizontalAlignment="Right" 
								BorderBrush="Black" BorderThickness="10"
								Style="{DynamicResource ExecButton}"
								Command="{Binding ShowHeaderListAsync}"/>
					</Grid>

					<DataGrid Grid.Row="4"
							  x:Name="MyDataGrid1"
							  FrozenColumnCount="2"
							  d:ItemsSource="{d:SampleData ItemCount=5}" 
							  Style="{DynamicResource WinGridData}"
							  IsReadOnly="True"
							  AutoGenerateColumns="False"
							  SelectionMode="Single"
							  ScrollViewer.VerticalScrollBarVisibility="Auto"
							  VerticalAlignment="Stretch"
							  HorizontalAlignment="Stretch"
							  ItemsSource="{Binding Items}"
							  SelectedItem="{Binding Current}">
						<behaviors:Interaction.Triggers>
							<behaviors:EventTrigger EventName="PreviewMouseDoubleClick">
								<behaviors:InvokeCommandAction Command="{Binding GoToDetailTab}" 
													   CommandParameter="{Binding SelectedItem, ElementName=MyDataGrid1, FallbackValue={x:Null}}" />
							</behaviors:EventTrigger>
						</behaviors:Interaction.Triggers>
						<DataGrid.Columns> 
							<DataGridTextColumn Width="*" Binding="{Binding Id}" Header="伝票No" />
							<DataGridTextColumn Width="*" Header="受注日" >
								<DataGridTextColumn.Binding>
									<Binding Path="DenDay"
											 Mode="OneWay"
											 Converter="{StaticResource DateDisplayConverter}" />
								</DataGridTextColumn.Binding>
							</DataGridTextColumn>
							<DataGridTextColumn Width="*" Binding="{Binding VTokui.Cd}" Header="得意先" />
							<DataGridTextColumn Width="*" Binding="{Binding VTokui.Mei}" Header="得意先名" />
							<DataGridTextColumn Width="*" Binding="{Binding VSoko.Cd}" Header="倉庫" />
							<DataGridTextColumn Width="*" Binding="{Binding VSoko.Mei}" Header="倉庫先名" />
							<DataGridTextColumn Width="*" Binding="{Binding VTanji.Cd}" Header="展示会" />
							<DataGridTextColumn Width="*" Binding="{Binding VTanji.Mei}" Header="展示会名" />
							<DataGridTextColumn Width="*" Binding="{Binding Kubun}" Header="取引区分" />
							<DataGridTextColumn Width="*" Binding="{Binding SuTotal}" Header="数量計">
								<DataGridTextColumn.ElementStyle>
									<Style TargetType="TextBlock">
										<Setter Property="TextAlignment" Value="Right" />
									</Style>
								</DataGridTextColumn.ElementStyle>
							</DataGridTextColumn>
							<DataGridTextColumn Width="*" Binding="{Binding KingakuTotal}" Header="金額計">
								<DataGridTextColumn.ElementStyle>
									<Style TargetType="TextBlock">
										<Setter Property="TextAlignment" Value="Right" />
									</Style>
								</DataGridTextColumn.ElementStyle>
							</DataGridTextColumn>
						</DataGrid.Columns>
					</DataGrid>
					 
					<Grid Grid.Row="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<RadioButton Grid.Column="0" Content="一覧"
								     Margin="0,0,10,0"
									 IsChecked="{Binding PrintMode, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}"
									 GroupName="OutPutType"/>
						<RadioButton Grid.Column="1" Content="明細"
									 Margin="0,0,10,0"
									 IsChecked="{Binding PrintMode, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"
									 GroupName="OutPutType"/>
						<Button Grid.Column="2" 
								Margin="0,0,10,0"
								Style="{DynamicResource PrintIconBtn}"
								Command="{Binding PrintCommand}"/>
						<Button Grid.Column="3"
								Margin="0,0,10,0"
								Content="CSV出力"
								Style="{DynamicResource PrintIconBtn}"
								Command="{Binding CsvExportCommand}"/>

						<Button Grid.Column="5"
								Margin="0,0,10,0"
								Content="修正・照会(F6)" 
								Style="{DynamicResource UpdateIconBtn}" 
								Command="{Binding GoToDetailTab}"/>
						<Button Grid.Column="6"
								Margin="0,0,10,0"
								Style="{DynamicResource DeleteIconBtn}"
								Command="{Binding DeleteCommand}"/>
						<Button Grid.Column="7"
								Style="{DynamicResource BackBtn}" 
								Command="{Binding CloseCommand}"/>
					</Grid> 
				</Grid>
			</TabItem>
			<TabItem Header="修正・登録画面(Shift+F2)">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="450"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"   
							   VerticalContentAlignment="Center"
							   MinWidth="62" 
							   Content="伝票No" />
						<TextBox Grid.Row="0" Grid.Column="1"   
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding CurrentEdit.Id}"/>
						<Label Grid.Row="0" Grid.Column="2"   
							   VerticalContentAlignment="Center"
							   Content="受注日" />
						<DatePicker Grid.Row="0" Grid.Column="3"
									Margin="0,0,5,0"
									SelectedDate="{Binding UriageDate}"/>
						<Label Grid.Row="0" Grid.Column="4"   
							   VerticalContentAlignment="Center"
							   Content="納品日" />
						<DatePicker Grid.Row="0" Grid.Column="5"
									Margin="0,0,5,0"
									SelectedDate="{Binding CurrentEdit.NouhinDay, Converter={StaticResource DateConverter}}"/>
						<Button Grid.Row="0" Grid.Column="6"  
								Content="一括設定"
								Command="{Binding BatchSetDeliveryDateCommand}"
								Style="{DynamicResource BackBtn}"/>
						<Label Grid.Row="0" Grid.Column="7"   
							   VerticalContentAlignment="Center"
							   Content="取引区分" />
						<ComboBox Grid.Row="0" Grid.Column="8"
								  VerticalAlignment="Top"
								  VerticalContentAlignment="Center"
								  ItemsSource="{Binding KubunItems}"
								  DisplayMemberPath="Display"
								  SelectedValuePath="Value"
								  SelectedValue="{Binding CurrentEdit.Kubun, Mode=TwoWay}"
								  Style="{StaticResource SearchableComboBox1}"/>
						<Label Grid.Row="0" Grid.Column="9"   
							   VerticalContentAlignment="Center"
							   Content="掛率" />
						<TextBox Grid.Row="0" Grid.Column="10"  
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding CurrentEdit.Kakeritsu}"/> 
					</Grid>

					<Grid Grid.Row="1" Margin="0,0,0,5">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="3*"/>
							<ColumnDefinition Width="7*"/>
						</Grid.ColumnDefinitions>
						<Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="得意先" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.VTokui.Display}"/>
							<Button Grid.Row="0" Grid.Column="2" 
												Style="{StaticResource ListButton}"
												Command="{Binding SelectTokui}"/>
						</Grid>
						<Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="関連No1" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 Text="{Binding CurrentEdit.RelatedNo1}"
									 HorizontalContentAlignment="Right"
									 VerticalContentAlignment="Center"/>
							<Label Grid.Row="0" Grid.Column="2" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="関連No2" />
							<TextBox Grid.Row="0" Grid.Column="3"
									 Text="{Binding CurrentEdit.RelatedNo2}"
									 HorizontalContentAlignment="Right"
									 VerticalContentAlignment="Center"/>
							<Label Grid.Row="0" Grid.Column="4" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="手入力No" />
							<TextBox Grid.Row="0" Grid.Column="5"
									 Margin="0,0,5,0"
									 Text="{Binding CurrentEdit.ManualInputNo}"
									 HorizontalContentAlignment="Right"
									 VerticalContentAlignment="Center"/>
							<Button Grid.Row="0" Grid.Column="6"  
									Margin="0,0,5,0"
									Content="掛率一括展開"
									Command="{Binding ExpandRateCommand}"
									Style="{DynamicResource BackBtn}"/>
							<Button Grid.Row="0" Grid.Column="7"  
									Content="ｵｰﾙｸﾘｱ"
									Command="{Binding AllClearCommand}"
									Style="{DynamicResource BackBtn}"/>
						</Grid>

						<Grid Grid.Row="1" Grid.Column="0" Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="倉庫" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.VSoko.Display}"/>
							<Button Grid.Row="0" Grid.Column="2"
												Style="{StaticResource ListButton}"
												Command="{Binding SelectSoko}"/>
						</Grid>
						<Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="1.8*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="入力者" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.VShain.Display}"/>
							<Button Grid.Row="0" Grid.Column="2"
												Style="{StaticResource ListButton}"
												Command="{Binding SelectShain}"/>
							<Label Grid.Row="0" Grid.Column="3" 
								   VerticalContentAlignment="Center"
								   Content="展示会" />
							<TextBox Grid.Row="0" Grid.Column="4"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.VTanji.Display}"/>
							<Button Grid.Row="0" Grid.Column="5"
												Style="{StaticResource ListButton}"
												Command="{Binding SelectTenjiCommand}"/>
						</Grid>

						<Grid Grid.Row="2" Grid.Column="0" Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" /> 
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0" 
								   VerticalContentAlignment="Center"
								   MinWidth="62"
								   Content="備考" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.Biko}"/>
						</Grid>
						<Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								   VerticalContentAlignment="Center"
								   Content="営業担当" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.VEigyo.Display}"/>
							<Button Grid.Row="0" Grid.Column="2"
												Margin="0,0,5,0"
												Style="{StaticResource ListButton}"
												Command="{Binding SelectEigyoCommand}" />
							<TextBox Grid.Row="0" Grid.Column="3"
									 HorizontalContentAlignment="Left"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.VShohin.Display}"/>
							<Button Grid.Row="0" Grid.Column="4"
												Margin="0,0,5,0"
												Style="{StaticResource ListButton}"
												Command="{Binding SelectShohinHeaderCommand}"/>
							<Button Grid.Row="0" Grid.Column="5"   
									Content="展開商品CD"
									Command="{Binding ExpandShohinCommand}"
									Style="{DynamicResource BackBtn}"/>
						</Grid>
					</Grid>

					<StackPanel Grid.Row="2" 
								Margin="0,0,0,5" 
								HorizontalAlignment="Center"
								Width="300">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0" 
								   VerticalContentAlignment="Center" 
								   Content="計" />
							<TextBox Grid.Row="0" Grid.Column="1"
									 HorizontalContentAlignment="Right"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.SuTotal}"/>
							<TextBox Grid.Row="0" Grid.Column="2"
									 HorizontalContentAlignment="Right"
									 VerticalContentAlignment="Center"
									 Text="{Binding CurrentEdit.KingakuTotal}"/>
							<TextBox Grid.Row="0" Grid.Column="3"
								 HorizontalContentAlignment="Right"
								 VerticalContentAlignment="Center"
								 Text="{Binding CurrentEdit.JodaiTotal}"/>
						</Grid>
					</StackPanel>
					<StackPanel Grid.Row="2" 
								Margin="0,0,0,5" 
								HorizontalAlignment="Right">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Button Grid.Column="0" 
									Margin="0,0,5,0"
									Content="一括Refresh⇔"
									Command="{Binding RefreshAllCommand}"
									Style="{DynamicResource BackBtn}"/>
							<Button Grid.Column="1" 
									Margin="0,0,5,0"
									Content="ﾊﾞｰｺｰﾄﾞ入力"
									Command="{Binding BarcodeInputCommand}"
									Style="{DynamicResource BackBtn}"/>
						</Grid>
					</StackPanel>

					<DataGrid Grid.Row="3"
									  x:Name="DetailGrid"
									  d:ItemsSource="{d:SampleData ItemCount=5}"
									  ItemsSource="{Binding DetailItems}"
									  IsSynchronizedWithCurrentItem="True"
									  HeadersVisibility="Column"
									  GridLinesVisibility="All"
									  HorizontalGridLinesBrush="#B0B0B0"
									  VerticalGridLinesBrush="#B0B0B0"
									  BorderBrush="#707070"
									  BorderThickness="1">
						<DataGrid.Columns>
							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Text="商品CD" FontWeight="Bold"/>
											<TextBlock Text="商品名" FontWeight="Bold"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition/>
												<RowDefinition/>
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="6*"/>
												<ColumnDefinition Width="4*"/>
											</Grid.ColumnDefinitions>
											<TextBox Grid.Column="0" 
													 Text="{Binding Code_Shohin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Margin="0" Style="{StaticResource DataGridTextBox}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction 
															Command="{Binding DataContext.LookupShohinByCodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<Button Grid.Column="1" Content="一覧" 
													Margin="0" Padding="6" 
													Command="{Binding DataContext.SelectShohinCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
													CommandParameter="{Binding}" />
											<Border Grid.Row="1" Grid.ColumnSpan="2"  BorderBrush="DarkGray" BorderThickness="0,1,0,0">
												<TextBox Grid.Row="1" Grid.ColumnSpan="2" 
														 Text="{Binding Mei_Shohin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
														 Margin="0" Style="{StaticResource DataGridTextBox}">
													<behaviors:Interaction.Triggers>
														<behaviors:EventTrigger EventName="MouseDoubleClick">
															<behaviors:InvokeCommandAction
																	Command="{Binding DataContext.PrintShohinCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
																	CommandParameter="{Binding}" />
														</behaviors:EventTrigger>
													</behaviors:Interaction.Triggers>
												</TextBox>
											</Border>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Text="色" FontWeight="Bold"/>
											<TextBlock Text="色名" FontWeight="Bold"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition/>
												<RowDefinition/>
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="6*"/>
												<ColumnDefinition Width="4*"/>
											</Grid.ColumnDefinitions>
											<TextBox Grid.Column="0" 
													 Text="{Binding Code_Col, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Margin="0" Style="{StaticResource DataGridTextBox}"/>
											<Button Grid.Column="1" Content="一覧" 
													Margin="0" Padding="6" 
													Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
													CommandParameter="{Binding}" />
											<Border Grid.Row="1" Grid.ColumnSpan="2"  BorderBrush="DarkGray" BorderThickness="0,1,0,0">
												<TextBox Grid.Row="1" Grid.ColumnSpan="2" 
														 IsReadOnly="True"
														 Text="{Binding Mei_Col, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
														 Margin="0" Style="{StaticResource DataGridTextBox}"/>
											</Border>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Text="サイズ" FontWeight="Bold"/>
											<TextBlock Text="サイズ名" FontWeight="Bold"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition/>
												<RowDefinition/>
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="6*"/>
												<ColumnDefinition Width="4*"/>
											</Grid.ColumnDefinitions>
											<TextBox Grid.Column="0" 
													 Text="{Binding Code_Siz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Margin="0" 
													 Style="{StaticResource DataGridTextBox}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction 
																Command="{Binding DataContext.GridSizeChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
																CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<Button Grid.Column="1" Content="一覧" 
													Margin="0" Padding="6" 
													Command="{Binding DataContext.SelectSizeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
													CommandParameter="{Binding}" />
											<Border Grid.Row="1" Grid.ColumnSpan="2"  BorderBrush="DarkGray" BorderThickness="0,1,0,0">
												<TextBox Grid.Row="1" Grid.ColumnSpan="2"
														 IsReadOnly="True"
														 Text="{Binding Mei_Siz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
														 Margin="0" Style="{StaticResource DataGridTextBox}"/>
											</Border>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="0.5*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Text="数量" FontWeight="Bold"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBox Text="{Binding Su, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
												 HorizontalContentAlignment="Right"
												 Style="{StaticResource DataGridTextBox}">
											<behaviors:Interaction.Triggers>
												<behaviors:EventTrigger EventName="TextChanged">
													<behaviors:InvokeCommandAction 
														Command="{Binding DataContext.QuantityChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
														CommandParameter="{Binding}" />
												</behaviors:EventTrigger>
											</behaviors:Interaction.Triggers>
										</TextBox>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Text="単価" FontWeight="Bold"/>
											<TextBlock Text="金額" FontWeight="Bold"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition/>
												<RowDefinition/>
											</Grid.RowDefinitions>
											<TextBox Grid.Column="0" 
													 HorizontalContentAlignment="Right"
													 Text="{Binding Tanka, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Style="{StaticResource DataGridTextBox}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction 
															Command="{Binding DataContext.UnitPriceChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<TextBox Grid.Row="1"
													 IsReadOnly="True"
													 HorizontalContentAlignment="Right"
													 Text="{Binding Kingaku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Style="{StaticResource DataGridTextBox}"/>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Text="上代" FontWeight="Bold"/>
											<TextBlock Text="上代金額" FontWeight="Bold"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition/>
												<RowDefinition/>
											</Grid.RowDefinitions>
											<TextBox Grid.Column="0" 
													 HorizontalContentAlignment="Right"
													 Text="{Binding Jodai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Style="{StaticResource DataGridTextBox}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction 
															Command="{Binding DataContext.JodaiChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<TextBox Grid.Row="1"
													 IsReadOnly="True"
													 HorizontalContentAlignment="Right"
													 Text="{Binding JodaiAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
													 Style="{StaticResource DataGridTextBox}"/>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>

					<Grid Grid.Row="4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0" 
								Margin="0,0,5,0"
								Content="行追加" 
								Style="{DynamicResource ExecButton}"
								Command="{Binding AddDetailRow}"/>
						<Button Grid.Column="1" 
								Margin="0,0,5,0"
								Content="行削除" 
								Style="{DynamicResource ExecButton}"
								Command="{Binding RemoveDetailRow}"/>
						<Button Grid.Column="2" 
								Margin="0,0,5,0"
								Content="再計算" 
								Style="{DynamicResource ExecButton}"
								Command="{Binding RecalculateSummary}"/>

						<Button Grid.Column="5"
								Margin="0,0,10,0"
								Content="新規(F7)" 
								Style="{DynamicResource NewIconBtn}" 
								Command="{Binding NewCommand}"/>
						<Button Grid.Column="6"
								Margin="0,0,10,0"
								Content="保存(F10)" 
								Style="{DynamicResource SaveIconBtn}" 
								Command="{Binding SaveCommand}"/>
						<Button Grid.Column="7"
								Margin="0,0,10,0"
								Content="削除" 
								Style="{DynamicResource DeleteIconBtn}" 
								Command="{Binding DeleteCurrentCommand}"/>
						<Button Grid.Column="8"
								Margin="0,0,10,0"
								Content="再読込" 
								Style="{DynamicResource ReloadIconBtn}" 
								Command="{Binding ReloadSlip}"/>
						<Button Grid.Column="9"
								Style="{DynamicResource BackBtn}" 
								Command="{Binding CloseCommand}"/>
					</Grid>
				</Grid>
			</TabItem>
		</TabControl>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Column="0" 
					   VerticalAlignment="Center"
					   Text="{Binding Message}" />
			<TextBlock Grid.Column="1" 
					   VerticalAlignment="Center"
					   Text="{Binding StatusMessage}" />
		</Grid>
	</Grid>
</helpers:BaseWindow>
