<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._04Juchu.JuchuInputView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:local="clr-namespace:Cvnet10Wpfclient.Views" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._04Juchu"
	Title="展示会受注入力"
	Width="1400" Height="900"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:JuchuInputViewModel />
	</helpers:BaseWindow.DataContext>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TabControl Grid.Row="0"
			HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
			d:DataContext="{d:DesignInstance Type=vm:JuchuInputViewModel,
																																				IsDesignTimeCreatable=True}"
			BorderThickness="1"
			SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
			<TabItem Header="検索画面(Shift+F1)">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="340" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<Grid Grid.Row="0"
						Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="伝票No" />
						<TextBox Grid.Row="0" Grid.Column="1"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.FromId}" />
						<TextBlock Grid.Row="0" Grid.Column="2"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="0" Grid.Column="3"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.ToId}" />
						<Label Grid.Row="0" Grid.Column="4"
							VerticalContentAlignment="Center"
							Content="受注日" />
						<DatePicker Grid.Row="0" Grid.Column="5"
							materialDesign:HintAssist.Hint="開始日付" FontSize="15" IsTodayHighlighted="False"
							SelectedDate="{Binding SelectInitParam.FromDate, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
						<TextBlock Grid.Row="0" Grid.Column="6"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<DatePicker Grid.Row="0" Grid.Column="7"
							materialDesign:HintAssist.Hint="終了日付" FontSize="15" IsTodayHighlighted="False"
							SelectedDate="{Binding SelectInitParam.ToDate, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
						<Label Grid.Row="0" Grid.Column="8"
							VerticalContentAlignment="Center"
							Content="取引区分" />
						<TextBox Grid.Row="0" Grid.Column="9"
							VerticalAlignment="Top" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.KubunFrom}" />
						<TextBlock Grid.Row="0" Grid.Column="10"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="0" Grid.Column="11"
							VerticalAlignment="Top" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.KubunTo}" />
					</Grid>

					<Grid Grid.Row="1"
						Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="関連No1" />
						<TextBox Grid.Row="0" Grid.Column="1"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.RelatedNo1From}" />
						<TextBlock Grid.Row="0" Grid.Column="2"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="0" Grid.Column="3"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.RelatedNo1To}" />
						<Label Grid.Row="0" Grid.Column="4"
							VerticalContentAlignment="Center"
							Content="関連No2" />
						<TextBox Grid.Row="0" Grid.Column="5"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.RelatedNo2From}" />
						<TextBlock Grid.Row="0" Grid.Column="6"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="0" Grid.Column="7"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.RelatedNo2To}" />
						<Label Grid.Row="0" Grid.Column="8"
							VerticalContentAlignment="Center"
							Content="手入力No" />
						<TextBox Grid.Row="0" Grid.Column="9"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.ManualInputNoFrom}" />
						<TextBlock Grid.Row="0" Grid.Column="10"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="0" Grid.Column="11"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.ManualInputNoTo}" />
					</Grid>

					<Grid Grid.Row="2"
						Margin="0,0,0,5">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="5" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1.04*" />
							<ColumnDefinition Width="4*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="4*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="得意先" />
						<TextBox Grid.Row="0" Grid.Column="1"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.TokuiName}" />
						<Button Grid.Row="0" Grid.Column="2"
							Command="{Binding SelectTokuiCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />
						<TextBlock Grid.Row="0" Grid.Column="3"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="0" Grid.Column="4"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.TokuiNameTo}" />
						<Button Grid.Row="0" Grid.Column="5"
							Command="{Binding SelectTokuiToCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />

						<Label Grid.Row="2" Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="倉庫" />
						<TextBox Grid.Row="2" Grid.Column="1"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.SokoName}" />
						<Button Grid.Row="2" Grid.Column="2"
							Command="{Binding SelectSokoCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />
						<TextBlock Grid.Row="2" Grid.Column="3"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="2" Grid.Column="4"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.SokoNameTo}" />
						<Button Grid.Row="2" Grid.Column="5"
							Command="{Binding SelectSokoToCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />

						<Button Grid.Row="4" Grid.Column="0"
							VerticalContentAlignment="Center"
							Command="{Binding ToggleShohinCommand}"
							Content="商品" />
						<TextBox Grid.Row="4" Grid.Column="1"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.ShohinName}" />
						<Button Grid.Row="4" Grid.Column="2"
							Command="{Binding SelectShohinCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />
						<TextBlock Grid.Row="4" Grid.Column="3"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="4" Grid.Column="4"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.ShohinNameTo}" />
						<Button Grid.Row="4" Grid.Column="5"
							Command="{Binding SelectShohinToCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />

						<Label Grid.Row="6" Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="展示会" />
						<TextBox Grid.Row="6" Grid.Column="1"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.TenjiName}" />
						<Button Grid.Row="6" Grid.Column="2"
							Command="{Binding SelectTenjiCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />
						<TextBlock Grid.Row="6" Grid.Column="3"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="6" Grid.Column="4"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.TenjiNameTo}" />
						<Button Grid.Row="6" Grid.Column="5"
							Command="{Binding SelectTenjiToCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />

						<Label Grid.Row="8" Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="入力者" />
						<TextBox Grid.Row="8" Grid.Column="1"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.InputUserName}" />
						<Button Grid.Row="8" Grid.Column="2"
							Command="{Binding SelectInputUserCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />
						<TextBlock Grid.Row="8" Grid.Column="3"
							VerticalAlignment="Center"
							Foreground="Black" Text="～" />
						<TextBox Grid.Row="8" Grid.Column="4"
							HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
							Text="{Binding SelectInitParam.InputUserNameTo}" />
						<Button Grid.Row="8" Grid.Column="5"
							Command="{Binding SelectInputUserToCommand}"
							Style="{StaticResource MaterialDesignFlatButton}" />
					</Grid>

					<Grid Grid.Row="3"
						Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition />
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0"
							HorizontalAlignment="Left"
							Orientation="Horizontal">
							<Button Margin="0,0,5,0" HorizontalAlignment="Right"
								BorderBrush="Black" BorderThickness="10"
								Command="{Binding PrevPageCommand}"
								Style="{DynamicResource PrevPageBtn}" />
							<Button HorizontalAlignment="Right"
								BorderBrush="Black" BorderThickness="10"
								Command="{Binding NextPageCommand}"
								Style="{DynamicResource NextPageBtn}" />
						</StackPanel>
						<Button Grid.Column="1"
							HorizontalAlignment="Right"
							BorderBrush="Black" BorderThickness="10"
							Command="{Binding ShowHeaderListAsync}"
							Content="一覧取得(F5)"
							Style="{DynamicResource ExecButton}" />
					</Grid>

					<DataGrid x:Name="MyDataGrid1"
						Grid.Row="4"
						HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
						d:ItemsSource="{d:SampleData ItemCount=5}"
						AutoGenerateColumns="False" FrozenColumnCount="2" IsReadOnly="True"
						ItemsSource="{Binding Items}"
						ScrollViewer.VerticalScrollBarVisibility="Auto"
						SelectedItem="{Binding Current}"
						SelectionMode="Single"
						Style="{DynamicResource WinGridData}">
						<behaviors:Interaction.Triggers>
							<behaviors:EventTrigger EventName="PreviewMouseDoubleClick">
								<behaviors:InvokeCommandAction Command="{Binding GoToDetailTab}"
									CommandParameter="{Binding SelectedItem, ElementName=MyDataGrid1, FallbackValue={x:Null}}" />
							</behaviors:EventTrigger>
						</behaviors:Interaction.Triggers>
						<DataGrid.Columns>
							<DataGridTextColumn Width="*"
								Binding="{Binding Id}"
								Header="伝票No" />
							<DataGridTextColumn Width="*"
								Header="受注日">
								<DataGridTextColumn.Binding>
									<Binding Converter="{StaticResource DateYmd8Converter}"
										Mode="OneWay" Path="DenDay" />
								</DataGridTextColumn.Binding>
							</DataGridTextColumn>
							<DataGridTextColumn Width="*"
								Binding="{Binding VTokui.Cd}"
								Header="得意先" />
							<DataGridTextColumn Width="*"
								Binding="{Binding VTokui.Mei}"
								Header="得意先名" />
							<DataGridTextColumn Width="*"
								Binding="{Binding VSoko.Cd}"
								Header="倉庫" />
							<DataGridTextColumn Width="*"
								Binding="{Binding VSoko.Mei}"
								Header="倉庫先名" />
							<DataGridTextColumn Width="*"
								Binding="{Binding VTanji.Cd}"
								Header="展示会" />
							<DataGridTextColumn Width="*"
								Binding="{Binding VTanji.Mei}"
								Header="展示会名" />
							<DataGridTextColumn Width="*"
								Binding="{Binding Kubun}"
								Header="取引区分" />
							<DataGridTextColumn Width="*"
								Binding="{Binding SuTotal}"
								Header="数量計">
								<DataGridTextColumn.ElementStyle>
									<Style TargetType="TextBlock">
										<Setter Property="TextAlignment" Value="Right" />
									</Style>
								</DataGridTextColumn.ElementStyle>
							</DataGridTextColumn>
							<DataGridTextColumn Width="*"
								Binding="{Binding KingakuTotal}"
								Header="金額計">
								<DataGridTextColumn.ElementStyle>
									<Style TargetType="TextBlock">
										<Setter Property="TextAlignment" Value="Right" />
									</Style>
								</DataGridTextColumn.ElementStyle>
							</DataGridTextColumn>
						</DataGrid.Columns>
					</DataGrid>

					<Grid Grid.Row="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<RadioButton Grid.Column="0"
							Margin="0,0,10,0"
							Content="一覧" GroupName="OutPutType"
							IsChecked="{Binding PrintMode, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}" />
						<RadioButton Grid.Column="1"
							Margin="0,0,10,0"
							Content="明細" GroupName="OutPutType"
							IsChecked="{Binding PrintMode, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}" />
						<Button Grid.Column="2"
							Margin="0,0,10,0"
							Command="{Binding PrintCommand}"
							Style="{DynamicResource PrintIconBtn}" />
						<Button Grid.Column="3"
							Margin="0,0,10,0"
							Command="{Binding CsvExportCommand}"
							Content="CSV出力"
							Style="{DynamicResource PrintIconBtn}" />

						<Button Grid.Column="5"
							Margin="0,0,10,0"
							Command="{Binding GoToDetailTab}"
							Content="修正・照会(F6)"
							Style="{DynamicResource UpdateIconBtn}" />
						<Button Grid.Column="6"
							Margin="0,0,10,0"
							Command="{Binding DeleteCommand}"
							Style="{DynamicResource DeleteIconBtn}" />
						<Button Grid.Column="7"
							Command="{Binding CloseCommand}"
							Style="{DynamicResource BackBtn}" />
					</Grid>
				</Grid>
			</TabItem>
			<TabItem Header="修正・登録画面(Shift+F2)">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="450" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<Grid Grid.Row="0"
						Margin="0,0,0,5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Row="0" Grid.Column="0"
							MinWidth="62"
							VerticalContentAlignment="Center"
							Content="伝票No" />
						<TextBox Grid.Row="0" Grid.Column="1"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding CurrentEdit.Id}" />
						<Label Grid.Row="0" Grid.Column="2"
							VerticalContentAlignment="Center"
							Content="受注日" />
						<DatePicker Grid.Row="0" Grid.Column="3"
							Margin="0,0,5,0"
							SelectedDate="{Binding UriageDate}" />
						<Label Grid.Row="0" Grid.Column="4"
							VerticalContentAlignment="Center"
							Content="納品日" />
						<DatePicker Grid.Row="0" Grid.Column="5"
							Margin="0,0,5,0"
							SelectedDate="{Binding CurrentEdit.NouhinDay, Converter={StaticResource DateYmd8Converter}}" />
						<Button Grid.Row="0" Grid.Column="6"
							Command="{Binding BatchSetDeliveryDateCommand}"
							Content="一括設定"
							Style="{DynamicResource BackBtn}" />
						<Label Grid.Row="0" Grid.Column="7"
							VerticalContentAlignment="Center"
							Content="取引区分" />
						<ComboBox Grid.Row="0" Grid.Column="8"
							VerticalAlignment="Top" VerticalContentAlignment="Center"
							DisplayMemberPath="Display"
							ItemsSource="{Binding KubunItems}"
							SelectedValue="{Binding CurrentEdit.Kubun, Mode=TwoWay}"
							SelectedValuePath="Value"
							Style="{StaticResource MaterialDesignComboBox}" />
						<Label Grid.Row="0" Grid.Column="9"
							VerticalContentAlignment="Center"
							Content="掛率" />
						<TextBox Grid.Row="0" Grid.Column="10"
							HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
							Text="{Binding CurrentEdit.Kakeritsu}" />
					</Grid>

					<Grid Grid.Row="1"
						Margin="0,0,0,5">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="3*" />
							<ColumnDefinition Width="7*" />
						</Grid.ColumnDefinitions>
						<Grid Grid.Row="0" Grid.Column="0"
							Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="得意先" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.VTokui.Display}" />
							<Button Grid.Row="0" Grid.Column="2"
								Command="{Binding SelectTokui}"
								Style="{StaticResource MaterialDesignFlatButton}" />
						</Grid>
						<Grid Grid.Row="0" Grid.Column="1"
							Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="関連No1" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.RelatedNo1}" />
							<Label Grid.Row="0" Grid.Column="2"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="関連No2" />
							<TextBox Grid.Row="0" Grid.Column="3"
								HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.RelatedNo2}" />
							<Label Grid.Row="0" Grid.Column="4"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="手入力No" />
							<TextBox Grid.Row="0" Grid.Column="5"
								Margin="0,0,5,0" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.ManualInputNo}" />
							<Button Grid.Row="0" Grid.Column="6"
								Margin="0,0,5,0"
								Command="{Binding ExpandRateCommand}"
								Content="掛率一括展開"
								Style="{DynamicResource BackBtn}" />
							<Button Grid.Row="0" Grid.Column="7"
								Command="{Binding AllClearCommand}"
								Content="ｵｰﾙｸﾘｱ"
								Style="{DynamicResource BackBtn}" />
						</Grid>

						<Grid Grid.Row="1" Grid.Column="0"
							Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="倉庫" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.VSoko.Display}" />
							<Button Grid.Row="0" Grid.Column="2"
								Command="{Binding SelectSoko}"
								Style="{StaticResource MaterialDesignFlatButton}" />
						</Grid>
						<Grid Grid.Row="1" Grid.Column="1"
							Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="1.8*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="入力者" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.VShain.Display}" />
							<Button Grid.Row="0" Grid.Column="2"
								Command="{Binding SelectShain}"
								Style="{StaticResource MaterialDesignFlatButton}" />
							<Label Grid.Row="0" Grid.Column="3"
								VerticalContentAlignment="Center"
								Content="展示会" />
							<TextBox Grid.Row="0" Grid.Column="4"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.VTanji.Display}" />
							<Button Grid.Row="0" Grid.Column="5"
								Command="{Binding SelectTenjiCommand}"
								Style="{StaticResource MaterialDesignFlatButton}" />
						</Grid>

						<Grid Grid.Row="2" Grid.Column="0"
							Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								MinWidth="62"
								VerticalContentAlignment="Center"
								Content="備考" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.Biko}" />
						</Grid>
						<Grid Grid.Row="2" Grid.Column="1"
							Margin="0,0,0,5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="3*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								VerticalContentAlignment="Center"
								Content="営業担当" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.VEigyo.Display}" />
							<Button Grid.Row="0" Grid.Column="2"
								Margin="0,0,5,0"
								Command="{Binding SelectEigyoCommand}"
								Style="{StaticResource MaterialDesignFlatButton}" />
							<TextBox Grid.Row="0" Grid.Column="3"
								HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.VShohin.Display}" />
							<Button Grid.Row="0" Grid.Column="4"
								Margin="0,0,5,0"
								Command="{Binding SelectShohinHeaderCommand}"
								Style="{StaticResource MaterialDesignFlatButton}" />
							<Button Grid.Row="0" Grid.Column="5"
								Command="{Binding ExpandShohinCommand}"
								Content="展開商品CD"
								Style="{DynamicResource BackBtn}" />
						</Grid>
					</Grid>

					<StackPanel Grid.Row="2"
						Width="300"
						Margin="0,0,0,5" HorizontalAlignment="Center">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<Label Grid.Row="0" Grid.Column="0"
								VerticalContentAlignment="Center"
								Content="計" />
							<TextBox Grid.Row="0" Grid.Column="1"
								HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.SuTotal}" />
							<TextBox Grid.Row="0" Grid.Column="2"
								HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.KingakuTotal}" />
							<TextBox Grid.Row="0" Grid.Column="3"
								HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
								Text="{Binding CurrentEdit.JodaiTotal}" />
						</Grid>
					</StackPanel>
					<StackPanel Grid.Row="2"
						Margin="0,0,0,5" HorizontalAlignment="Right">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Button Grid.Column="0"
								Margin="0,0,5,0"
								Command="{Binding RefreshAllCommand}"
								Content="一括Refresh⇔"
								Style="{DynamicResource BackBtn}" />
							<Button Grid.Column="1"
								Margin="0,0,5,0"
								Command="{Binding BarcodeInputCommand}"
								Content="ﾊﾞｰｺｰﾄﾞ入力"
								Style="{DynamicResource BackBtn}" />
						</Grid>
					</StackPanel>

					<DataGrid x:Name="DetailGrid"
						Grid.Row="3"
						d:ItemsSource="{d:SampleData ItemCount=5}"
						BorderBrush="#707070" BorderThickness="1" GridLinesVisibility="All" HeadersVisibility="Column" HorizontalGridLinesBrush="#B0B0B0" IsSynchronizedWithCurrentItem="True"
						ItemsSource="{Binding DetailItems}"
						VerticalGridLinesBrush="#B0B0B0">
						<DataGrid.Columns>
							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="商品CD" />
											<TextBlock FontWeight="Bold" Text="商品名" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition />
												<RowDefinition />
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="6*" />
												<ColumnDefinition Width="4*" />
											</Grid.ColumnDefinitions>
											<TextBox Grid.Column="0"
												Margin="0"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Code_Shohin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction Command="{Binding DataContext.LookupShohinByCodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<Button Grid.Column="1"
												Margin="0" Padding="6"
												Command="{Binding DataContext.SelectShohinCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
												CommandParameter="{Binding}"
												Content="一覧" />
											<Border Grid.Row="1" Grid.ColumnSpan="2"
												BorderBrush="DarkGray" BorderThickness="0,1,0,0">
												<TextBox Grid.Row="1" Grid.ColumnSpan="2"
													Margin="0"
													Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
													Text="{Binding Mei_Shohin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
													<behaviors:Interaction.Triggers>
														<behaviors:EventTrigger EventName="MouseDoubleClick">
															<behaviors:InvokeCommandAction Command="{Binding DataContext.PrintShohinCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
																CommandParameter="{Binding}" />
														</behaviors:EventTrigger>
													</behaviors:Interaction.Triggers>
												</TextBox>
											</Border>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="色" />
											<TextBlock FontWeight="Bold" Text="色名" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition />
												<RowDefinition />
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="6*" />
												<ColumnDefinition Width="4*" />
											</Grid.ColumnDefinitions>
											<TextBox Grid.Column="0"
												Margin="0"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Code_Col, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
											<Button Grid.Column="1"
												Margin="0" Padding="6"
												Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
												CommandParameter="{Binding}"
												Content="一覧" />
											<Border Grid.Row="1" Grid.ColumnSpan="2"
												BorderBrush="DarkGray" BorderThickness="0,1,0,0">
												<TextBox Grid.Row="1" Grid.ColumnSpan="2"
													Margin="0"
													IsReadOnly="True"
													Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
													Text="{Binding Mei_Col, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
											</Border>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="サイズ" />
											<TextBlock FontWeight="Bold" Text="サイズ名" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition />
												<RowDefinition />
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="6*" />
												<ColumnDefinition Width="4*" />
											</Grid.ColumnDefinitions>
											<TextBox Grid.Column="0"
												Margin="0"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Code_Siz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction Command="{Binding DataContext.GridSizeChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<Button Grid.Column="1"
												Margin="0" Padding="6"
												Command="{Binding DataContext.SelectSizeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
												CommandParameter="{Binding}"
												Content="一覧" />
											<Border Grid.Row="1" Grid.ColumnSpan="2"
												BorderBrush="DarkGray" BorderThickness="0,1,0,0">
												<TextBox Grid.Row="1" Grid.ColumnSpan="2"
													Margin="0"
													IsReadOnly="True"
													Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
													Text="{Binding Mei_Siz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
											</Border>
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="0.5*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="数量" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBox HorizontalContentAlignment="Right"
											Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
											Text="{Binding Su, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
											<behaviors:Interaction.Triggers>
												<behaviors:EventTrigger EventName="TextChanged">
													<behaviors:InvokeCommandAction Command="{Binding DataContext.QuantityChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
														CommandParameter="{Binding}" />
												</behaviors:EventTrigger>
											</behaviors:Interaction.Triggers>
										</TextBox>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="単価" />
											<TextBlock FontWeight="Bold" Text="金額" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition />
												<RowDefinition />
											</Grid.RowDefinitions>
											<TextBox Grid.Column="0"
												HorizontalContentAlignment="Right"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Tanka, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction Command="{Binding DataContext.UnitPriceChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<TextBox Grid.Row="1"
												HorizontalContentAlignment="Right"
												IsReadOnly="True"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Kingaku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="上代" />
											<TextBlock FontWeight="Bold" Text="上代金額" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition />
												<RowDefinition />
											</Grid.RowDefinitions>
											<TextBox Grid.Column="0"
												HorizontalContentAlignment="Right"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Jodai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
												<behaviors:Interaction.Triggers>
													<behaviors:EventTrigger EventName="TextChanged">
														<behaviors:InvokeCommandAction Command="{Binding DataContext.JodaiChangedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
															CommandParameter="{Binding}" />
													</behaviors:EventTrigger>
												</behaviors:Interaction.Triggers>
											</TextBox>
											<TextBox Grid.Row="1"
												HorizontalContentAlignment="Right"
												IsReadOnly="True"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding JodaiAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTemplateColumn Width="*">
								<DataGridTemplateColumn.HeaderTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock FontWeight="Bold" Text="納品日" />
											<TextBlock FontWeight="Bold" Text="備考" />
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.HeaderTemplate>
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition />
												<RowDefinition />
											</Grid.RowDefinitions>
											<TextBox Grid.Row="0"
												Height="30"
												HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding NouhinDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DateYmd8Converter}}" />
											<TextBox Grid.Row="1"
												HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
												Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
												Text="{Binding Biko, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
										</Grid>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>

					<Grid Grid.Row="4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0"
							Margin="0,0,5,0"
							Command="{Binding AddDetailRow}"
							Content="行追加"
							Style="{DynamicResource ExecButton}" />
						<Button Grid.Column="1"
							Margin="0,0,5,0"
							Command="{Binding RemoveDetailRow}"
							Content="行削除"
							Style="{DynamicResource ExecButton}" />
						<Button Grid.Column="2"
							Margin="0,0,5,0"
							Command="{Binding RecalculateSummary}"
							Content="再計算"
							Style="{DynamicResource ExecButton}" />

						<Button Grid.Column="5"
							Margin="0,0,10,0"
							Command="{Binding NewCommand}"
							Content="新規(F7)"
							Style="{DynamicResource NewIconBtn}" />
						<Button Grid.Column="6"
							Margin="0,0,10,0"
							Command="{Binding SaveCommand}"
							Content="保存(F10)"
							Style="{DynamicResource SaveIconBtn}" />
						<Button Grid.Column="7"
							Margin="0,0,10,0"
							Command="{Binding DeleteCurrentCommand}"
							Content="削除"
							Style="{DynamicResource DeleteIconBtn}" />
						<Button Grid.Column="8"
							Margin="0,0,10,0"
							Command="{Binding ReloadSlip}"
							Content="再読込"
							Style="{DynamicResource ReloadIconBtn}" />
						<Button Grid.Column="9"
							Command="{Binding CloseCommand}"
							Style="{DynamicResource BackBtn}" />
					</Grid>
				</Grid>
			</TabItem>
		</TabControl>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Column="0"
				VerticalAlignment="Center"
				Text="{Binding Message}" />
			<TextBlock Grid.Column="1"
				VerticalAlignment="Center"
				Text="{Binding StatusMessage}" />
		</Grid>
	</Grid>
</helpers:BaseWindow>
