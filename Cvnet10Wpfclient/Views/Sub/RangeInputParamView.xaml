<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views.Sub.RangeInputParamView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels.Sub"
	Title="{Binding Parameter.DisplayName, TargetNullValue=入力, StringFormat={}{0}一覧条件}"
	Width="620" Height="640"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="18" WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:RangeInputParamViewModel />
	</helpers:BaseWindow.DataContext>
	<helpers:BaseWindow.Resources>
		<Style x:Key="FormTextBox"
			BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
			TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.7" />
		</Style>
	</helpers:BaseWindow.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8" ClipToBounds="True"
			materialDesign:ElevationAssist.Elevation="Dp4"
			Mode="PrimaryMid">
			<StackPanel Orientation="Horizontal">
				<materialDesign:PackIcon Width="28" Height="28"
					VerticalAlignment="Center"
					Kind="DatabaseSearch" />
				<TextBlock Margin="10,0,0,0"
					VerticalAlignment="Center"
					FontSize="20" FontWeight="SemiBold"
					Text="{Binding Parameter.DisplayName, TargetNullValue=入力, StringFormat={}{0}選択}" />
			</StackPanel>
		</materialDesign:ColorZone>

		<Grid Grid.Row="1" Margin="16,12,16,12">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0"
				Margin="0,0,0,8"
				FontSize="18" FontWeight="Bold"
				Foreground="{DynamicResource MaterialDesignBody}"
				Text="{Binding Parameter.DisplayName, TargetNullValue=入力, StringFormat={}{0}一覧の対象範囲を指定してください}" />

			<materialDesign:Card Grid.Row="1"
				Padding="12,12,12,0"
				materialDesign:ElevationAssist.Elevation="Dp2"
				UniformCornerRadius="8">
				<Grid Margin="2">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="150" />
						<ColumnDefinition Width="160" />
						<ColumnDefinition Width="10" />
						<ColumnDefinition Width="40" />
						<ColumnDefinition Width="180" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Row="0" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="伝票No" /></TextBlock>
					<TextBox Grid.Row="0" Grid.Column="1"
						Margin="4,4,4,4" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="伝票No (開始)"
						Style="{StaticResource FormTextBox}"
						TabIndex="0"
						Text="{Binding Parameter.FromId, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="0" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<TextBox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="伝票No (終了)"
						Style="{StaticResource FormTextBox}"
						TabIndex="1"
						Text="{Binding Parameter.ToId, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="1" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="日付" /></TextBlock>
					<DatePicker Grid.Row="1" Grid.Column="1"
						Margin="4,4,4,4" VerticalContentAlignment="Center"
						FontSize="16" IsTodayHighlighted="False"
						SelectedDate="{Binding Parameter.FromDate, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
						TabIndex="2" />

					<TextBlock Grid.Row="1" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<DatePicker Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" VerticalContentAlignment="Center"
						FontSize="16" IsTodayHighlighted="False"
						SelectedDate="{Binding Parameter.ToDate, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
						TabIndex="3" />

					<TextBlock Grid.Row="2" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="仕入先CD" /></TextBlock>
					<TextBox Grid.Row="2" Grid.Column="1"
						Margin="4,4,4,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="仕入先CD (開始)"
						Style="{StaticResource FormTextBox}"
						TabIndex="4"
						Text="{Binding Parameter.FromToriCd, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="2" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<TextBox Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="仕入先CD (終了)"
						Style="{StaticResource FormTextBox}"
						TabIndex="5"
						Text="{Binding Parameter.ToToriCd, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="3" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="入庫先CD" /></TextBlock>
					<TextBox Grid.Row="3" Grid.Column="1"
						Margin="4,4,4,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="入庫先CD (開始)"
						Style="{StaticResource FormTextBox}"
						TabIndex="6"
						Text="{Binding Parameter.FromSokoCd, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="3" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<TextBox Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="入庫先CD (終了)"
						Style="{StaticResource FormTextBox}"
						TabIndex="7"
						Text="{Binding Parameter.ToSokoCd, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="4" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="商品CD" /></TextBlock>
					<TextBox Grid.Row="4" Grid.Column="1"
						Margin="4,4,4,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="商品CD (開始)"
						Style="{StaticResource FormTextBox}"
						TabIndex="8"
						Text="{Binding Parameter.FromShohinCd, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="4" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<TextBox Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="商品CD (終了)"
						Style="{StaticResource FormTextBox}"
						TabIndex="9"
						Text="{Binding Parameter.ToShohinCd, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="5" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="件数" /></TextBlock>
					<TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
						Margin="4,4,4,4" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="件数"
						Style="{StaticResource FormTextBox}"
						TabIndex="10"
						Text="{Binding Parameter.MaxCount, UpdateSourceTrigger=PropertyChanged}" />
					<TextBlock Grid.Row="5" Grid.Column="3" Grid.ColumnSpan="3"
						VerticalAlignment="Center"
						Foreground="{DynamicResource MaterialDesignBodyLight}" Text="(空白:全件取得)" />

				</Grid>
			</materialDesign:Card>
		</Grid>

		<StackPanel Grid.Row="2"
			Margin="12" HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button Width="120" Height="38"
				Margin="0,0,8,0"
				Command="{Binding OkCommand}"
				IsDefault="True"
				Style="{StaticResource MaterialDesignRaisedButton}">
				<StackPanel Orientation="Horizontal">
					<materialDesign:PackIcon VerticalAlignment="Center"
						Kind="CheckCircle" />
					<TextBlock Margin="6,0,0,0"
						VerticalAlignment="Center"
						FontSize="16"
						Text="選択確定" />
				</StackPanel>
			</Button>
			<Button Width="140" Height="38"
				Command="{Binding ExitCommand}"
				IsCancel="True"
				Style="{StaticResource MaterialDesignFlatButton}">
				<StackPanel Orientation="Horizontal">
					<materialDesign:PackIcon VerticalAlignment="Center"
						Kind="ArrowLeft" />
					<TextBlock Margin="6,0,0,0"
						VerticalAlignment="Center"
						FontSize="16"
						Text="戻る" />
				</StackPanel>
			</Button>
		</StackPanel>
	</Grid>
</helpers:BaseWindow>
