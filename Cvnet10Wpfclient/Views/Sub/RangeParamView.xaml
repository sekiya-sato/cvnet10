<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views.Sub.RangeParamView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels.Sub"
	Title="{Binding Parameter.DisplayName, StringFormat={}{0}選択}"
	Width="620" Height="520"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="18" WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:RangeParamViewModel />
	</helpers:BaseWindow.DataContext>
	<helpers:BaseWindow.Resources>
		<!--  編集フォームの TextBox スタイル  -->
		<Style x:Key="FormTextBox"
			BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
			TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.7" />
		</Style>
	</helpers:BaseWindow.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  Header: ColorZone Toolbar  -->
		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" ClipToBounds="True" Mode="PrimaryMid">
			<StackPanel Orientation="Horizontal">
				<materialDesign:PackIcon Width="28" Height="28"
					VerticalAlignment="Center"
					Kind="DatabaseSearch" />
				<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
					FontSize="20" FontWeight="SemiBold"
					Text="{Binding Parameter.DisplayName, StringFormat={}{0}選択}" />
			</StackPanel>
		</materialDesign:ColorZone>

		<!--  Main Content  -->
		<Grid Grid.Row="1"
			Margin="16">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0"
				Margin="0,0,0,8"
				FontSize="18" FontWeight="Bold"
				Foreground="{DynamicResource MaterialDesignBody}"
				Text="{Binding Parameter.DisplayName, StringFormat={}{0}一覧の対象範囲を指定してください}" />

			<materialDesign:Card Grid.Row="1"
				Padding="12,12,12,0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<Grid Margin="2">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="150" />
						<ColumnDefinition Width="160" />
						<ColumnDefinition Width="10" />
						<ColumnDefinition Width="40" />
						<ColumnDefinition Width="180" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Row="0" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="ID" /></TextBlock>
					<TextBox Grid.Row="0" Grid.Column="1"
						Margin="4,4,4,4" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="ID (開始)"
						Style="{StaticResource FormTextBox}"
						Text="{Binding Parameter.FromId, UpdateSourceTrigger=PropertyChanged}" />





					<TextBlock Grid.Row="0" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<TextBox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="ID (終了)"
						Style="{StaticResource FormTextBox}"
						Text="{Binding Parameter.ToId, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="1" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource MaterialDesignBodyLight}"
						Text="{Binding Parameter.DisplayName, StringFormat={}{0}CD}" />
					<TextBox Grid.Row="1" Grid.Column="1"
						Margin="4,4,4,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="CD (開始)"
						Style="{StaticResource FormTextBox}"
						Text="{Binding Parameter.FromCode, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="1" Grid.Column="3"
						HorizontalAlignment="Center" VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="-" /></TextBlock>
					<TextBox Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
						Margin="4,4,0,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="CD (終了)"
						Style="{StaticResource FormTextBox}"
						Text="{Binding Parameter.ToCode, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="2" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="名前(部分一致)" /></TextBlock>
					<TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5"
						Margin="4,4,4,4" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="名前"
						Style="{StaticResource FormTextBox}"
						Text="{Binding Parameter.Name, UpdateSourceTrigger=PropertyChanged}" />

					<TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6"
						Margin="0,8,0,0"
						Foreground="{DynamicResource MaterialDesignBodyLight}"
						Text="{Binding Parameter.DisplayName, StringFormat={}範囲を指定しない場合、すべての{0}が対象になります。}"
						TextWrapping="Wrap" />

					<TextBlock Grid.Row="4" Grid.Column="0"
						VerticalAlignment="Center"
						FontWeight="Medium"
						Foreground="{DynamicResource MaterialDesignBodyLight}"><Run Language="ja-jp" Text="件数" /></TextBlock>
					<TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
						Margin="4,4,4,4" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
						materialDesign:HintAssist.Hint="件数"
						Style="{StaticResource FormTextBox}"
						Text="{Binding Parameter.MaxCount, UpdateSourceTrigger=PropertyChanged}" />
					<TextBlock Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="3"
						VerticalAlignment="Center"
						Foreground="{DynamicResource MaterialDesignBodyLight}"
						Text="(空白:全件取得)" />

				</Grid>
			</materialDesign:Card>

			<StackPanel Grid.Row="2"
				Margin="0,16,0,0" HorizontalAlignment="Right"
				Orientation="Horizontal">
				<Button Width="120" Height="38"
					Margin="0,0,8,0"
					Command="{Binding OkCommand}"
					IsDefault="True"
					Style="{StaticResource MaterialDesignRaisedButton}">
					<StackPanel Orientation="Horizontal">
						<materialDesign:PackIcon VerticalAlignment="Center"
							Kind="CheckCircle" />
						<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
							FontSize="16" Text="選択確定" />
					</StackPanel>
				</Button>
				<Button Width="140" Height="38"
					Command="{Binding ExitCommand}"
					IsCancel="True"
					Style="{StaticResource MaterialDesignFlatButton}">
					<StackPanel Orientation="Horizontal">
						<materialDesign:PackIcon VerticalAlignment="Center"
							Kind="ArrowLeft" />
						<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
							FontSize="16" Text="戻る" />
					</StackPanel>
				</Button>
			</StackPanel>
		</Grid>
	</Grid>
</helpers:BaseWindow>
