<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views.Sub.SelectShainView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels.Sub"
	Title="社員範囲選択"
	Width="620"
	Height="420"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="18"
	WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:SelectShainViewModel />
	</helpers:BaseWindow.DataContext>

	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<TextBlock Grid.Row="0"
			Margin="0,0,0,12"
			FontSize="20"
			FontWeight="Bold"
			Foreground="{DynamicResource MaterialDesignBody}">
			社員一覧の対象範囲を指定してください
		</TextBlock>

		<Border Grid.Row="1"
			Padding="16"
			Background="{DynamicResource MaterialDesignPaper}"
			CornerRadius="6">
			<Grid Margin="8">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="150" />
					<ColumnDefinition Width="180" />
					<ColumnDefinition Width="10" />
					<ColumnDefinition Width="40" />
					<ColumnDefinition Width="180" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
					Grid.Column="0"
					VerticalAlignment="Center"
					FontWeight="SemiBold"
					><Run Language="ja-jp" Text="Id"/></TextBlock>
                <TextBox Grid.Row="0"
					Grid.Column="1"
					Height="36"
					Margin="4,4,4,4"
					VerticalContentAlignment="Center"
					FontSize="16"
					Text="{Binding FromId, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="0"
					Grid.Column="3"
					VerticalAlignment="Center"
					HorizontalAlignment="Center"
					FontWeight="SemiBold"
					><Run Language="ja-jp" Text="-"/></TextBlock>
                <TextBox Grid.Row="0"
					Grid.Column="4"
					Grid.ColumnSpan="2"
					Height="36"
					Margin="4,4,0,4"
					VerticalContentAlignment="Center"
					FontSize="16"
					Text="{Binding ToId, UpdateSourceTrigger=PropertyChanged}" />

				<TextBlock Grid.Row="1"
					Grid.Column="0"
					VerticalAlignment="Center"
					FontWeight="SemiBold"
					Text="社員CD From" />
				<TextBox Grid.Row="1"
					Grid.Column="1"
					Height="36"
					Margin="4,4,4,4"
					VerticalContentAlignment="Center"
					FontSize="16"
					Text="{Binding FromCode, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
					Grid.Column="3"
					VerticalAlignment="Center"
					HorizontalAlignment="Center"
					FontWeight="SemiBold"
					><Run Language="ja-jp" Text="-"/></TextBlock>
                <TextBox Grid.Row="1"
					Grid.Column="4"
					Grid.ColumnSpan="2"
					Height="36"
					Margin="4,4,0,4"
					VerticalContentAlignment="Center"
					FontSize="16"
					Text="{Binding ToCode, UpdateSourceTrigger=PropertyChanged}" />

				<TextBlock Grid.Row="2"
					Grid.Column="0"
					Grid.ColumnSpan="6"
					Margin="0,12,0,0"
					Foreground="Gray"
					TextWrapping="Wrap">
					範囲を指定しない場合、すべての社員が対象になります。
				</TextBlock>
			</Grid>
		</Border>

		<StackPanel Grid.Row="2"
			Margin="0,16,0,0"
			HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button Width="120"
				Height="38"
				Margin="0,0,8,0"
				Background="DarkSlateBlue"
				Command="{Binding OkCommand}"
				Content="選択確定"
				FontSize="16"
				Foreground="White"
				IsDefault="True" />
			<Button Width="140"
				Height="38"
				Background="Gray"
				Command="{Binding ExitCommand}"
				Content="戻る"
				FontSize="16"
				Foreground="White"
				IsCancel="True" />
		</StackPanel>
	</Grid>
</helpers:BaseWindow>
