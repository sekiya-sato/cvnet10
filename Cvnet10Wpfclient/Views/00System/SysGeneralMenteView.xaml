<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._00System.SysGeneralMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._00System"
	Title="{Binding Title}"
	Width="1320" Height="920"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="16"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:SysGeneralMenteViewModel />
	</helpers:BaseWindow.DataContext>

	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoSaveCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoAddCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoReloadCommand}"
			Gesture="F5" />
	</helpers:BaseWindow.InputBindings>

	<helpers:BaseWindow.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

		<Style x:Key="MenteDataGridColumnHeader"
			BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
			TargetType="DataGridColumnHeader">
			<Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}" />
			<Setter Property="Padding" Value="12,8" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<Style x:Key="FormLabel"
			TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
			<Setter Property="Margin" Value="4,0,8,0" />
		</Style>

		<Style x:Key="FormTextBox"
			BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
			TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.7" />
		</Style>
	</helpers:BaseWindow.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" Mode="PrimaryMid">
			<DockPanel>
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button Margin="4,0"
						Command="{Binding DoSaveCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="保存 (F2)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="ContentSave" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="保存" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoDeleteCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="削除 (F3)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Delete" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="削除" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoAddCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="追加 (F4)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Plus" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="追加" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoReloadCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="再読込 (F5)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Refresh" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="再読込" />
						</StackPanel>
					</Button>
				</StackPanel>

				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0"
						Command="{Binding ExitCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="閉じる (Esc)">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<materialDesign:PackIcon Width="28" Height="28"
						VerticalAlignment="Center"
						Kind="TableEdit" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
						FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>

		<Grid Grid.Row="1"
			Margin="12">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="36*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="64*" />
			</Grid.ColumnDefinitions>

			<materialDesign:Card Grid.Row="0" Grid.Column="0"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<Border Grid.Row="0"
						Padding="12,8"
						Background="{DynamicResource MaterialDesignToolBarBackground}"
						CornerRadius="8,8,0,0">
						<DockPanel>
							<TextBlock VerticalAlignment="Center"
								DockPanel.Dock="Right" FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Count, StringFormat={}件数: {0:N0}}" />
							<TextBlock VerticalAlignment="Center"
								FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="一覧" />
						</DockPanel>
					</Border>

					<ListBox Grid.Row="1"
						ItemsSource="{Binding Rows}"
						SelectedItem="{Binding SelectedRow}"
						BorderThickness="0"
						Background="Transparent"
						ScrollViewer.HorizontalScrollBarVisibility="Disabled">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border Padding="10,8"
									BorderBrush="{DynamicResource MaterialDesignDivider}"
									BorderThickness="0,0,0,1">
										<StackPanel>
											<TextBlock FontWeight="SemiBold"
												Text="{Binding Title}" />
											<TextBlock Margin="0,4,0,0"
												FontSize="12"
												Foreground="{DynamicResource MaterialDesignBodyLight}"
												Text="{Binding Id, StringFormat={}Id: {0}}" />
										</StackPanel>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</Grid>
			</materialDesign:Card>

			<GridSplitter Grid.Row="0" Grid.Column="1"
				Width="6"
				Margin="3,0"
				HorizontalAlignment="Center"
				VerticalAlignment="Stretch"
				Background="Transparent" />

			<materialDesign:Card Grid.Row="0" Grid.Column="2"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<Border Grid.Row="0"
						Padding="16,10"
						Background="{DynamicResource MaterialDesignToolBarBackground}"
						CornerRadius="8,8,0,0">
						<DockPanel>
							<TextBlock VerticalAlignment="Center"
								FontSize="18"
								FontWeight="SemiBold"
								Text="{Binding SelectedRow.Title, TargetNullValue=レコード未選択}" />
<TextBlock DockPanel.Dock="Right"
										VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBodyLight}"
										Text="{Binding SelectedRow.OriginalType.Name, StringFormat={}対象型: {0}, TargetNullValue=対象型: -}" />
					<TextBlock DockPanel.Dock="Right"
										Margin="10,0,0,0"
										VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBodyLight}"
										Text="{Binding SelectedRow.Vdc, StringFormat={}Vdc: {0:yyyy/MM/dd HH:mm}, TargetNullValue=Vdc: -}" />
					<TextBlock DockPanel.Dock="Right"
										Margin="10,0,0,0"
										VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBodyLight}"
										Text="{Binding SelectedRow.Vdu, StringFormat={}Vdu: {0:yyyy/MM/dd HH:mm}, TargetNullValue=Vdu: -}" />
						</DockPanel>
					</Border>

					<Grid Grid.Row="1">
						<TextBlock HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Foreground="{DynamicResource MaterialDesignBodyLight}"
							Text="左の一覧からレコードを選択してください。">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Visibility" Value="Collapsed" />
									<Style.Triggers>
										<DataTrigger Binding="{Binding HasSelection}" Value="False">
											<Setter Property="Visibility" Value="Visible" />
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>

						<ScrollViewer Padding="12,10,20,20"
							VerticalScrollBarVisibility="Auto">
							<ItemsControl ItemsSource="{Binding SelectedRow.Cells}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid Margin="0,0,0,10">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="180" />
												<ColumnDefinition Width="*" />
											</Grid.ColumnDefinitions>

											<TextBlock Grid.Column="0"
												Style="{StaticResource FormLabel}"
												Text="{Binding Header}" />

											<TextBox Grid.Column="1" Style="{StaticResource FormTextBox}" IsReadOnly="True" Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</ScrollViewer>
					</Grid>
				</Grid>
			</materialDesign:Card>

			<Border Grid.Row="1" Grid.ColumnSpan="3"
				Margin="0,12,0,0"
				Padding="12,8"
				Background="{DynamicResource MaterialDesignPaper}"
				BorderBrush="{DynamicResource MaterialDesignDivider}"
				BorderThickness="1"
				CornerRadius="8">
				<TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
			</Border>
		</Grid>
	</Grid>
</helpers:BaseWindow>
