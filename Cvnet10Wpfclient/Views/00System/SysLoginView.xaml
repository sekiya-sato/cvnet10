<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._00System.SysLoginView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:local="clr-namespace:Cvnet10Wpfclient.Views" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._00System"
	Title="{Binding Title}"
	Width="1000" Height="740"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="19"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:SysLoginViewModel />
	</helpers:BaseWindow.DataContext>

	<!--  SearchTextBox 共通スタイル  -->
	<helpers:BaseWindow.Resources>
		<Style x:Key="MenteSearchTextBox"
			TargetType="{x:Type helpers:SearchTextBox}">
			<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
			<Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
			<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
		</Style>

		<!--  DataGrid ヘッダースタイル（テーマカラーベース）  -->
		<Style x:Key="MenteDataGridColumnHeader"
			BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
			TargetType="DataGridColumnHeader">
			<Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}" />
			<Setter Property="Padding" Value="12,8" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<!--  編集フォームのラベルスタイル  -->
		<Style x:Key="FormLabel"
			TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
			<Setter Property="Margin" Value="4,0,8,0" />
		</Style>

		<!--  編集フォームの TextBox スタイル  -->
		<Style x:Key="FormTextBox"
			BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
			TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.7" />
		</Style>
	</helpers:BaseWindow.Resources>
	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoOutputJsonCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  ===== ヘッダー: ColorZone ツールバー =====  -->
		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" Mode="PrimaryMid">
			<DockPanel>
				<!--  右側: CRUD ボタン群  -->
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button Margin="4,0"
						Command="{Binding DoUpdateCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="修正 (F2)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Pencil" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="修正" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoDeleteCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="削除 (F3)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Delete" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="削除" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoInsertCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="追加 (F4)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Plus" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="追加" />
						</StackPanel>
					</Button>
					<Rectangle Width="1"
						Margin="8,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Margin="4,0"
						Command="{Binding DoOutputJsonCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="JSON出力 (F6)">
						<materialDesign:PackIcon Kind="FileExport" />
					</Button>
				</StackPanel>

				<!--  左側: タイトル + 操作  -->
				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0"
						Command="{Binding ExitCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="閉じる (Esc)">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<materialDesign:PackIcon Width="28" Height="28"
						VerticalAlignment="Center"
						Kind="AccountKey" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
						FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
					<Rectangle Width="1"
						Margin="16,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Command="{Binding DoListCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="一覧取得 (F5)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="DatabaseSearch" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="一覧取得" />
						</StackPanel>
					</Button>
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>

		<!--  ===== メインコンテンツ =====  -->
		<Grid Grid.Row="1"
			Margin="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>
			<!--  ===== 左パネル: 一覧グリッド (Card) =====  -->
			<materialDesign:Card Grid.Column="0"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<!--  カードヘッダー: 件数 + メッセージ  -->
					<Border Grid.Row="0"
						Padding="12,8"
						Background="{DynamicResource MaterialDesignToolBarBackground}"
						CornerRadius="8,8,0,0">
						<DockPanel>
							<TextBlock VerticalAlignment="Center"
								DockPanel.Dock="Right" FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Count, StringFormat={}件数: {0:N0}}" />
							<TextBlock VerticalAlignment="Center"
								FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Message}"
								TextTrimming="CharacterEllipsis" />
						</DockPanel>
					</Border>

					<!--  DataGrid 一覧  -->
					<DataGrid x:Name="LoginGrid"
						Grid.Row="1"
						d:ItemsSource="{d:SampleData ItemCount=5}"
						helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" materialDesign:DataGridAssist.CellPadding="12,6" materialDesign:DataGridAssist.ColumnHeaderPadding="12,8"
						AutoGenerateColumns="False" EnableRowVirtualization="True" FrozenColumnCount="1" GridLinesVisibility="Horizontal"
						HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
						IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
						ItemsSource="{Binding ListData}"
						SelectedItem="{Binding Current}"
						Style="{StaticResource MaterialDesignDataGrid}"
						VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
						<DataGrid.Columns>
							<!--  LoginId,ExpDate,LastDate,CryptPassword,Id,Vdc,Vdu,Id_Shain,Id_Role  -->
							<DataGridTextColumn Binding="{Binding LoginId}"
								Header="Login ID" />
							<DataGridTextColumn Binding="{Binding ExpDate, Converter={StaticResource DateTimeYmdHmsConverter}}"
								Header="有効期限" />
							<DataGridTextColumn Binding="{Binding LastDate, Converter={StaticResource DateTimeYmdHmsConverter}}"
								Header="最終ログイン" />
							<DataGridTextColumn Binding="{Binding CryptPassword}"
								Header="パスワード" />
							<DataGridTextColumn Binding="{Binding VdateC}"
								Header="作成日" />
							<DataGridTextColumn Binding="{Binding VdateU}"
								Header="修正日" />
							<DataGridTextColumn Binding="{Binding Id}"
								Header="Id" />
							<DataGridTextColumn Binding="{Binding Id_Shain}"
								Header="社員Id" />
							<DataGridTextColumn Binding="{Binding Id_Role}"
								Header="グループId" />
						</DataGrid.Columns>
						<DataGrid.ColumnHeaderStyle>
							<Style BasedOn="{StaticResource MenteDataGridColumnHeader}"
								TargetType="DataGridColumnHeader" />
						</DataGrid.ColumnHeaderStyle>
					</DataGrid>
				</Grid>
			</materialDesign:Card>

			<!--  スプリッタ  -->
			<GridSplitter Grid.Column="1"
				Width="6"
				Margin="3,0" HorizontalAlignment="Center" VerticalAlignment="Stretch"
				Background="Transparent" />
			<!--  ===== 右パネル: 編集エリア (Card + TabControl) =====  -->
			<materialDesign:Card Grid.Column="2"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<TabControl Style="{StaticResource MaterialDesignTabControl}">

					<!--  タブ1: 基本情報  -->
					<TabItem>
						<TabItem.Header>
							<StackPanel Orientation="Horizontal">
								<materialDesign:PackIcon Margin="0,0,6,0" VerticalAlignment="Center"
									Kind="InformationOutline" />
								<TextBlock Text="{Binding CurrentEdit.Id, StringFormat={}Id:{0}}" />
							</StackPanel>
						</TabItem.Header>
						<ScrollViewer Padding="10,10,20,20"
							VerticalScrollBarVisibility="Auto">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="110" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<!--  ID  -->
								<TextBlock Grid.Row="0"
									Style="{StaticResource FormLabel}"
									Text="ID" />
								<TextBox Grid.Row="0" Grid.Column="1"
									materialDesign:HintAssist.Hint="ID"
									Style="{StaticResource FormTextBox}"
									IsReadOnly="True"
									Text="{Binding CurrentEdit.Id}" />

								<!--  Login ID  -->
								<TextBlock Grid.Row="1"
									Style="{StaticResource FormLabel}"
									Text="Login ID" />
								<TextBox Grid.Row="1" Grid.Column="1"
									materialDesign:HintAssist.Hint="Login ID"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.LoginId}" />

								<!--  パスワード  -->
								<TextBlock Grid.Row="2"
									Style="{StaticResource FormLabel}"
									Text="パスワード" />
								<TextBox Grid.Row="2" Grid.Column="1"
									materialDesign:HintAssist.Hint="パスワード"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.CryptPassword}" />

								<!--  有効期限  -->
								<TextBlock Grid.Row="3"
									Style="{StaticResource FormLabel}"
									Text="有効期限" />
								<TextBox Grid.Row="3" Grid.Column="1"
									materialDesign:HintAssist.Hint="有効期限"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.ExpDate, Converter={StaticResource DateTimeYmdHmsConverter}}" />

								<!--  Group  -->
								<TextBlock Grid.Row="4"
									Style="{StaticResource FormLabel}"
									Text="Group" />
								<TextBox Grid.Row="4" Grid.Column="1"
									Width="120" Height="36"
									HorizontalAlignment="Left"
									materialDesign:HintAssist.Hint="Group"
									Style="{StaticResource FormTextBox}"
									IsReadOnly="True"
									Text="{Binding CurrentEdit.Id_Role}" />

								<!--  社員選択  -->
								<TextBlock Grid.Row="5"
									Style="{StaticResource FormLabel}"
									Text="社員" />
								<DockPanel Grid.Row="5" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectShainCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Shain, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VShain.Cd" />
												<Binding Path="CurrentEdit.VShain.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<!--  最終ログイン  -->
								<TextBlock Grid.Row="6"
									Style="{StaticResource FormLabel}"
									Text="最終ログイン" />
								<TextBox Grid.Row="6" Grid.Column="1"
									materialDesign:HintAssist.Hint="最終ログイン"
									Style="{StaticResource FormTextBox}"
									IsReadOnly="True"
									Text="{Binding LastLoginDate}" />

								<!--  パスワード設定ボタン  -->
								<TextBlock Grid.Row="7"
									Style="{StaticResource FormLabel}"
									Text="" />
								<Button Grid.Row="7" Grid.Column="1"
									Width="120" Height="36"
									Margin="0,4" HorizontalAlignment="Left"
									Command="{Binding DoSetPassCommand}"
									Style="{StaticResource MaterialDesignOutlinedButton}">
									<StackPanel Orientation="Horizontal">
										<materialDesign:PackIcon VerticalAlignment="Center"
											Kind="Lock" />
										<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
											Text="パス暗号化" />
									</StackPanel>
								</Button>

								<!--  作成日/修正日  -->
								<TextBlock Grid.Row="8"
									Style="{StaticResource FormLabel}"
									Text="作成日/修正日" />
								<TextBlock Grid.Row="8" Grid.Column="1"
									Margin="0,4" VerticalAlignment="Center"
									Foreground="{DynamicResource MaterialDesignBody}"
									FontSize="14">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} - {1}">
											<Binding Path="CurrentEdit.VdateC" />
											<Binding Path="CurrentEdit.VdateU" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>
							</Grid>
						</ScrollViewer>
					</TabItem>

				</TabControl>
			</materialDesign:Card>



		</Grid>

	</Grid>
</helpers:BaseWindow>
