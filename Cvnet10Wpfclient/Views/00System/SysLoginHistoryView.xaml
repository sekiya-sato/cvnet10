<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._00System.SysLoginHistoryView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:local="clr-namespace:Cvnet10Wpfclient.Views" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._00System"
	Title="{Binding Title}"
	Width="1000" Height="740"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="19"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:SysLoginHistoryViewModel />
	</helpers:BaseWindow.DataContext>
	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoOutputJsonCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>
	<Grid x:Name="grid0">
		<Grid Width="{Binding ActualWidth, ElementName=grid0, Mode=OneWay}"
			Height="{Binding ActualHeight, ElementName=grid0, Mode=OneWay}">
			<Grid.RowDefinitions>
				<RowDefinition Height="12*" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="88*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>
			<Grid Grid.Row="0" Grid.Column="0">
				<Button Width="70" Height="30"
					Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Gray"
					Command="{Binding ExitCommand}"
					Content="閉じる" />
				<Button Width="110" Height="30"
					Margin="106,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Command="{Binding DoListCommand}"
					Content="一覧取得 F5" />
				<Button Width="100" Height="30"
					Margin="242,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Command="{Binding DoOutputJsonCommand}"
					Content="JSON出力 F6" />
				<Label Height="34"
					Margin="20,49,99,0" VerticalAlignment="Top"
					d:Content="Title"
					Content="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
					FontSize="14" />
				<materialDesign:PackIcon Width="62" Height="70"
					Margin="362,10,0,0"
					Foreground="Blue" Kind="History" />
			</Grid>
			<GridSplitter Grid.Row="1" Grid.ColumnSpan="3"
				Height="3"
				Margin="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
				Background="DarkGray" />
			<GridSplitter Grid.RowSpan="3" Grid.Column="1"
				Width="3"
				Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Stretch"
				Background="DarkGray" />
			<Grid Grid.Row="2" Grid.Column="0">
				<DataGrid d:ItemsSource="{d:SampleData ItemCount=5}"
					AutoGenerateColumns="False"
					Background="{DynamicResource AppCommonBackgroundBrush}"
					FrozenColumnCount="1" IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
					ItemsSource="{Binding ListData}"
					SelectedItem="{Binding Current}">
					<DataGrid.ColumnHeaderStyle>
						<Style TargetType="DataGridColumnHeader">
							<Setter Property="Background" Value="Black" />
							<Setter Property="BorderBrush" Value="White" />
							<Setter Property="BorderThickness" Value="1" />
							<Setter Property="Foreground" Value="white" />
						</Style>
					</DataGrid.ColumnHeaderStyle>
					<DataGrid.Columns>
						<!--  Id,Id_Login,ExpDate,Ip,Op,VdateC  -->
						<DataGridTextColumn Binding="{Binding Id}"
							Header="Id" />
						<DataGridTextColumn Binding="{Binding Id_Login}"
							Header="ログインId" />
						<DataGridTextColumn Binding="{Binding ExpDate, Converter={StaticResource DateTimeYmdHmsConverter}}"
							Header="有効期限" />
						<DataGridTextColumn Binding="{Binding Ip}"
							Header="IP" />
						<DataGridTextColumn Binding="{Binding Op}"
							Header="操作" />
						<DataGridTextColumn Binding="{Binding VdateC, Converter={StaticResource DateTimeYmdHmsConverter}}"
							Header="登録日" />
					</DataGrid.Columns>
				</DataGrid>
			</Grid>
			<Grid Grid.Row="0" Grid.Column="2">
				<Label Height="40"
					Margin="10,10,0,0" VerticalAlignment="Top"
					d:Content="4567"
					Content="{Binding Count}"
					ContentStringFormat="{}件数={0:N0}" />
				<Label Height="34"
					Margin="24,55,0,0" VerticalAlignment="Top"
					d:Content="メッセージ"
					Content="{Binding Message}"
					FontSize="14" />
			</Grid>
			<Grid x:Name="Detail"
				Grid.Row="2" Grid.Column="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="30*" />
					<ColumnDefinition Width="70*" />
				</Grid.ColumnDefinitions>
				<Label Height="40"
					Margin="15,20,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="ログインId" />
				<Label Height="40"
					Margin="15,80,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="有効期限" />
				<Label Height="40"
					Margin="15,140,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="IP" />
				<Label Height="40"
					Margin="15,200,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="操作" />
				<Label Height="40"
					Margin="15,260,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="マシン名" />
				<Label Height="40"
					Margin="15,320,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="ユーザー" />
				<Label Height="40"
					Margin="15,380,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="OS" />
				<Label Height="40"
					Margin="15,440,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="IPアドレス" />
				<Label Height="40"
					Margin="15,500,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="MACアドレス" />
				<Label Height="40"
					Margin="15,560,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					Content="登録日" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,20,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="123" IsReadOnly="True"
					Text="{Binding CurrentEdit.Id_Login}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,80,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="202612311000" IsReadOnly="True"
					Text="{Binding CurrentEdit.ExpDate, Converter={StaticResource DateTimeYmdHmsConverter}}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,140,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="192.168.1.1" IsReadOnly="True"
					Text="{Binding CurrentEdit.Ip}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,200,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="Login" IsReadOnly="True"
					Text="{Binding CurrentEdit.Op}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,260,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="PC-001" IsReadOnly="True"
					Text="{Binding CurrentEdit.Jsub.Machine}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,320,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="user01" IsReadOnly="True"
					Text="{Binding CurrentEdit.Jsub.User}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,380,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="Windows 11" IsReadOnly="True"
					Text="{Binding CurrentEdit.Jsub.OsVer}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,440,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="192.168.1.1" IsReadOnly="True"
					Text="{Binding CurrentEdit.Jsub.IpAddress}"
					TextWrapping="Wrap" />
				<TextBox Grid.Column="1"
					Height="40"
					Margin="10,500,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					d:Text="AA:BB:CC:DD:EE:FF" IsReadOnly="True"
					Text="{Binding CurrentEdit.Jsub.MacAddress}"
					TextWrapping="Wrap" />
				<TextBlock Grid.Column="1"
					Margin="10,566,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
					FontSize="16">
					<TextBlock.Text>
						<MultiBinding StringFormat="{}{0}">
							<Binding Path="CurrentEdit.VdateC" />
						</MultiBinding>
					</TextBlock.Text>
					<d:TextBlock.Text>2026/01/01 00:00:00</d:TextBlock.Text>
				</TextBlock>
				<Label Grid.Column="1"
					Height="40"
					Margin="141,20,0,0" VerticalAlignment="Top"
					d:Content="ID"
					Content="{Binding CurrentEdit.Id}"
					ContentStringFormat="{}Id={0}" />
			</Grid>
		</Grid>
	</Grid>
</helpers:BaseWindow>
