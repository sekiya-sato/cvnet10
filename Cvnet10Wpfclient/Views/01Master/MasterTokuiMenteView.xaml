<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._01Master.MasterTokuiMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._01Master"
	Title="{Binding Title}"
	Width="1244" Height="900"
	d:Height="1200"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="18"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterTokuiMenteViewModel />
	</helpers:BaseWindow.DataContext>

	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoOutputJsonCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>

	<Grid x:Name="grid0">
		<Grid Width="{Binding ActualWidth, ElementName=grid0, Mode=OneWay}"
			Height="{Binding ActualHeight, ElementName=grid0, Mode=OneWay}">
			<Grid.RowDefinitions>
				<RowDefinition Height="12*" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="88*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>

			<!--  左上: 操作ボタン / タイトル  -->
			<Grid Grid.Row="0" Grid.Column="0">
				<Button Width="70" Height="30"
					Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Gray"
					Command="{Binding ExitCommand}"
					Content="閉じる" />
				<Button Width="110" Height="30"
					Margin="120,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Command="{Binding DoListCommand}"
					Content="一覧取得 F5" />
				<Button Width="130" Height="30"
					Margin="240,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Command="{Binding DoOutputJsonCommand}"
					Content="JSON出力 F6" />
				<Label Height="34"
					Margin="20,49,99,0" VerticalAlignment="Top"
					Content="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
					FontSize="14" />
				<materialDesign:PackIcon Width="62" Height="70"
					Margin="370,10,0,0"
					Foreground="Blue" Kind="AccountGroup" />
			</Grid>

			<GridSplitter Grid.Row="1" Grid.ColumnSpan="3"
				Height="3"
				HorizontalAlignment="Stretch" VerticalAlignment="Center"
				Background="DarkGray" />
			<GridSplitter Grid.RowSpan="3" Grid.Column="1"
				Width="3"
				HorizontalAlignment="Center" VerticalAlignment="Stretch"
				Background="DarkGray" />

			<!--  左下: 一覧グリッド  -->
			<Grid Grid.Row="2" Grid.Column="0">
				<DataGrid x:Name="TokuiGrid"
					d:ItemsSource="{d:SampleData ItemCount=5}"
					helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" FrozenColumnCount="2" GridLinesVisibility="Horizontal"
					HorizontalGridLinesBrush="White" IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
					ItemsSource="{Binding ListData}"
					SelectedItem="{Binding Current}"
					Style="{StaticResource MaterialDesignDataGrid}"
					VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
					<DataGrid.Columns>
						<DataGridTextColumn Width="140"
							Binding="{Binding Code}"
							Header="コード" />
						<DataGridTextColumn Width="240"
							Binding="{Binding Name}"
							Header="名前" />
						<DataGridTextColumn Width="150"
							Binding="{Binding Ryaku}"
							Header="略称" />
						<DataGridTextColumn Width="150"
							Binding="{Binding Kana}"
							Header="カナ" />
						<DataGridTextColumn Width="100"
							Binding="{Binding TenType}"
							Header="種別" />
					</DataGrid.Columns>
					<DataGrid.ColumnHeaderStyle>
						<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
							TargetType="DataGridColumnHeader">
							<Setter Property="Background" Value="Black" />
							<Setter Property="Foreground" Value="White" />
							<Setter Property="BorderThickness" Value="0.5" />
						</Style>
					</DataGrid.ColumnHeaderStyle>
				</DataGrid>
			</Grid>

			<!--  右上: CRUD ボタン / メッセージ  -->
			<Grid Grid.Row="0" Grid.Column="2">
				<Button Width="100" Height="30"
					Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Purple"
					Command="{Binding DoUpdateCommand}"
					Content="修正 F2" />
				<Button Width="100" Height="30"
					Margin="130,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Purple"
					Command="{Binding DoDeleteCommand}"
					Content="削除 F3" />
				<Button Width="100" Height="30"
					Margin="250,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Purple"
					Command="{Binding DoInsertCommand}"
					Content="追加 F4" />
				<Label Height="40"
					Margin="383,10,0,0" VerticalAlignment="Top"
					Content="{Binding Count}"
					ContentStringFormat="{}件数={0:N0}" />
				<TextBlock Height="34"
					Margin="24,55,0,0" VerticalAlignment="Top"
					FontSize="16"
					Foreground="{DynamicResource MaterialDesignBody}"
					Text="{Binding Message}"
					TextWrapping="Wrap" />
			</Grid>

			<!--  右下: 編集エリア (TabControl)  -->
			<Grid Grid.Row="2" Grid.Column="2"
				Margin="10">
				<TabControl Style="{StaticResource MaterialDesignTabControl}">

					<!--  タブ1: 基本情報  -->
					<TabItem>
						<TabItem.Header>
							<TextBlock Text="{Binding CurrentEdit.Id, StringFormat={}Id:{0}}" />
						</TabItem.Header>
						<ScrollViewer VerticalScrollBarVisibility="Auto">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="30*" />
									<ColumnDefinition Width="70*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Label Grid.Row="0"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="コード" />
								<TextBox Grid.Row="0" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Code}"
									TextWrapping="Wrap" />

								<Label Grid.Row="1"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="名前" />
								<TextBox Grid.Row="1" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Name}"
									TextWrapping="Wrap" />

								<Label Grid.Row="2"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="略称" />
								<TextBox Grid.Row="2" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Ryaku}"
									TextWrapping="Wrap" />

								<Label Grid.Row="3"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="カナ" />
								<TextBox Grid.Row="3" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Kana}"
									TextWrapping="Wrap" />

								<Label Grid.Row="4"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="得意先種別" />
								<ComboBox Grid.Row="4" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									SelectedValue="{Binding CurrentEdit.TenType, Mode=TwoWay}"
									SelectedValuePath="Tag">
									<ComboBoxItem Content="倉庫" Tag="0" />
									<ComboBoxItem Content="卸先" Tag="1" />
									<ComboBoxItem Content="売仕店" Tag="3" />
									<ComboBoxItem Content="直営店" Tag="6" />
								</ComboBox>

								<Label Grid.Row="5"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="在庫管理" />
								<ComboBox Grid.Row="5" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									SelectedIndex="{Binding CurrentEdit.IsZaiko, Mode=TwoWay}">
									<ComboBoxItem Content="しない" />
									<ComboBoxItem Content="する" />
								</ComboBox>

								<Label Grid.Row="6"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="担当者" />
								<helpers:SearchTextBox Grid.Row="6" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectShainCommand}"
									Text="{Binding CurrentEdit.Id_Shain, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>
								<TextBlock Grid.Row="6" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VShain.Cd" />
											<Binding Path="CurrentEdit.VShain.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>

								<Label Grid.Row="7"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="掛率" />
								<TextBox Grid.Row="7" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.RateProper}"
									TextWrapping="Wrap" />

								<Label Grid.Row="8"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="セール掛率" />
								<TextBox Grid.Row="8" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.RateSale}"
									TextWrapping="Wrap" />

								<Label Grid.Row="9"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="郵便番号" />
								<TextBox Grid.Row="9" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.PostalCode}"
									TextWrapping="Wrap" />

								<Label Grid.Row="10"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="住所1" />
								<TextBox Grid.Row="10" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Address1}"
									TextWrapping="Wrap" />

								<Label Grid.Row="11"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="住所2" />
								<TextBox Grid.Row="11" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Address2}"
									TextWrapping="Wrap" />

								<Label Grid.Row="12"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="住所3" />
								<TextBox Grid.Row="12" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Address3}"
									TextWrapping="Wrap" />

								<Label Grid.Row="13"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="電話番号" />
								<TextBox Grid.Row="13" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Tel}"
									TextWrapping="Wrap" />
							</Grid>
						</ScrollViewer>
					</TabItem>

					<!--  タブ2: 支払情報  -->
					<TabItem Header="支払情報">
						<ScrollViewer VerticalScrollBarVisibility="Auto">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="30*" />
									<ColumnDefinition Width="70*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Label Grid.Row="0"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="メールアドレス" />
								<TextBox Grid.Row="0" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Mail}"
									TextWrapping="Wrap" />

								<Label Grid.Row="1"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="締日1" />
								<TextBox Grid.Row="1" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Shime1}"
									TextWrapping="Wrap" />

								<Label Grid.Row="2"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="締日2" />
								<TextBox Grid.Row="2" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Shime2}"
									TextWrapping="Wrap" />

								<Label Grid.Row="3"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="締日3" />
								<TextBox Grid.Row="3" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Shime3}"
									TextWrapping="Wrap" />

								<Label Grid.Row="4"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="入金月" />
								<TextBox Grid.Row="4" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.PayMonth}"
									TextWrapping="Wrap" />

								<Label Grid.Row="5"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="入金日" />
								<TextBox Grid.Row="5" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.PayDay}"
									TextWrapping="Wrap" />

								<Label Grid.Row="6"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="入金方法" />
								<helpers:SearchTextBox Grid.Row="6" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectPayMethodCommand}"
									Text="{Binding CurrentEdit.Id_PayMethod, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>
								<TextBlock Grid.Row="6" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VPayMethod.Cd" />
											<Binding Path="CurrentEdit.VPayMethod.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>

								<Label Grid.Row="7"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="請求フラグ" />
								<ComboBox Grid.Row="7" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									SelectedIndex="{Binding CurrentEdit.IsPay, Mode=TwoWay}">
									<ComboBoxItem Content="しない" />
									<ComboBoxItem Content="する" />
								</ComboBox>

								<Label Grid.Row="8"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="請求先" />
								<helpers:SearchTextBox Grid.Row="8" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectPaysakiCommand}"
									Text="{Binding CurrentEdit.Id_Paysaki, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>
								<TextBlock Grid.Row="8" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VPaysaki.Cd" />
											<Binding Path="CurrentEdit.VPaysaki.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>
							</Grid>
						</ScrollViewer>
					</TabItem>

					<!--  タブ3: 名称リスト  -->
					<TabItem Header="名称リスト">
						<DataGrid x:Name="JsubGrid"
							Margin="10"
							d:ItemsSource="{d:SampleData ItemCount=3}"
							helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
							HorizontalGridLinesBrush="White" IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
							ItemsSource="{Binding CurrentEdit.Jsub}"
							Style="{StaticResource MaterialDesignDataGrid}"
							VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
							<DataGrid.Columns>
								<DataGridTextColumn Width="100"
									Binding="{Binding Kb}"
									Header="区分" />
								<DataGridTextColumn Width="120"
									Binding="{Binding Cd}"
									Header="コード" />
								<DataGridTextColumn Width="200"
									Binding="{Binding Mei}"
									Header="名称" />
								<DataGridTextColumn Width="*"
									Binding="{Binding Kbname}"
									Header="区分名" />
							</DataGrid.Columns>
							<DataGrid.ColumnHeaderStyle>
								<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
									TargetType="DataGridColumnHeader">
									<Setter Property="Background" Value="Black" />
									<Setter Property="Foreground" Value="White" />
									<Setter Property="BorderThickness" Value="0.5" />
								</Style>
							</DataGrid.ColumnHeaderStyle>
						</DataGrid>
					</TabItem>

					<!--  タブ4: 詳細内容 (振込先)  -->
					<TabItem Header="詳細内容">
						<Grid Margin="10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="30*" />
								<ColumnDefinition Width="70*" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<Label Grid.Row="0"
								Height="36"
								Margin="5,5,0,0" VerticalAlignment="Top"
								Content="振込先1" />
							<TextBox Grid.Row="0" Grid.Column="1"
								Height="36"
								Margin="10,5,10,0" VerticalAlignment="Top"
								Foreground="{DynamicResource MaterialDesignBody}"
								Text="{Binding CurrentEdit.Jdetail.BankAccount1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								TextWrapping="Wrap" />

							<Label Grid.Row="1"
								Height="36"
								Margin="5,10,0,0" VerticalAlignment="Top"
								Content="振込先2" />
							<TextBox Grid.Row="1" Grid.Column="1"
								Height="36"
								Margin="10,10,10,0" VerticalAlignment="Top"
								Foreground="{DynamicResource MaterialDesignBody}"
								Text="{Binding CurrentEdit.Jdetail.BankAccount2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								TextWrapping="Wrap" />

							<Label Grid.Row="2"
								Height="36"
								Margin="5,10,0,0" VerticalAlignment="Top"
								Content="振込先3" />
							<TextBox Grid.Row="2" Grid.Column="1"
								Height="36"
								Margin="10,10,10,0" VerticalAlignment="Top"
								Foreground="{DynamicResource MaterialDesignBody}"
								Text="{Binding CurrentEdit.Jdetail.BankAccount3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
