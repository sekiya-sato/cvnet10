<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._01Master.MasterSysKanriMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._01Master"
	Title="{Binding Title}"
	Width="1280" Height="920"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="16"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterSysKanriMenteViewModel />
	</helpers:BaseWindow.DataContext>
	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}" Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}" Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}" Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}" Gesture="F5" />
	</helpers:BaseWindow.InputBindings>
	<helpers:BaseWindow.Resources>
		<Style x:Key="FormLabel" TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
			<Setter Property="Margin" Value="4,0,8,0" />
		</Style>
		<Style x:Key="FormTextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}" TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.72" />
		</Style>
	</helpers:BaseWindow.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,10"
			materialDesign:ElevationAssist.Elevation="Dp4"
			Mode="PrimaryMid">
			<DockPanel>
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button Margin="4,0" Command="{Binding DoUpdateCommand}" ToolTip="修正 (F2)"
						Style="{StaticResource MaterialDesignToolForegroundButton}">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon Kind="Pencil" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="修正" />
						</StackPanel>
					</Button>
					<Button Margin="4,0" Command="{Binding DoDeleteCommand}" ToolTip="削除 (F3)"
						Style="{StaticResource MaterialDesignToolForegroundButton}">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon Kind="Delete" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="削除" />
						</StackPanel>
					</Button>
					<Button Margin="4,0" Command="{Binding DoInsertCommand}" ToolTip="追加 (F4)"
						Style="{StaticResource MaterialDesignToolForegroundButton}">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon Kind="Plus" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="追加" />
						</StackPanel>
					</Button>
					<Button Margin="4,0" Command="{Binding DoListCommand}" ToolTip="一覧取得 (F5)"
						Style="{StaticResource MaterialDesignToolForegroundButton}">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon Kind="DatabaseSearch" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="一覧取得" />
						</StackPanel>
					</Button>
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0" Command="{Binding ExitCommand}" ToolTip="閉じる (Esc)"
						Style="{StaticResource MaterialDesignToolForegroundButton}">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<materialDesign:PackIcon Width="28" Height="28" VerticalAlignment="Center" Kind="Cog" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
					<Rectangle Width="1" Margin="16,4" Fill="{DynamicResource PrimaryHueMidForegroundBrush}" Opacity="0.3" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13"
						Foreground="{DynamicResource MaterialDesignBodyLight}" Text="システム管理情報" />
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>
		<Grid Grid.Row="1" Margin="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>
			<materialDesign:Card Grid.Column="0" Padding="0" materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<StackPanel>
					<Border Padding="12,8" Background="{DynamicResource MaterialDesignToolBarBackground}" CornerRadius="8,8,0,0">
						<TextBlock FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}" Text="概要" />
					</Border>
					<StackPanel Margin="12" >
						<TextBlock Text="ID" Style="{StaticResource FormLabel}" />
						<TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Current.Id, StringFormat={}ID: {0:N0}}" />
						<TextBlock Text="説明" Style="{StaticResource FormLabel}" />
						<TextBlock TextWrapping="Wrap" Text="{Binding Current.Desc0}" />
						<TextBlock Text="備考" Style="{StaticResource FormLabel}" />
						<TextBlock TextWrapping="Wrap" Text="{Binding Current.Remark}" />
					</StackPanel>
				</StackPanel>
			</materialDesign:Card>
			<GridSplitter Grid.Column="1" Width="6" Margin="3,0" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" />
			<materialDesign:Card Grid.Column="2" Padding="0" materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<Grid Margin="18">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="140" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Grid.Row="0" Style="{StaticResource FormLabel}" Text="会社名" />
						<TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.Name}" />
						<TextBlock Grid.Row="1" Style="{StaticResource FormLabel}" Text="郵便番号" />
						<TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.PostalCode}" />
						<TextBlock Grid.Row="2" Style="{StaticResource FormLabel}" Text="住所" />
						<TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.Address1}" />
						<TextBlock Grid.Row="3" Style="{StaticResource FormLabel}" Text="電話" />
						<TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.Tel}" />
						<TextBlock Grid.Row="4" Style="{StaticResource FormLabel}" Text="メール" />
						<TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.Mail}" />
						<TextBlock Grid.Row="5" Style="{StaticResource FormLabel}" Text="期首年月日" />
						<DatePicker Grid.Row="5" Grid.Column="1" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" IsTodayHighlighted="False" SelectedDate="{Binding Current.FiscalStartDate, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
						<TextBlock Grid.Row="6" Style="{StaticResource FormLabel}" Text="締日" />
						<ComboBox Grid.Row="6" Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedComboBox}" ItemsSource="{Binding ShimeBiItems}" SelectedItem="{Binding Current.EnShimeBi, Mode=TwoWay}" />
						<TextBlock Grid.Row="7" Style="{StaticResource FormLabel}" Text="修正有効日数" />
						<TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.ModifyDaysEx}" />
						<TextBlock Grid.Row="8" Style="{StaticResource FormLabel}" Text="先付有効日数" />
						<TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.ModifyDaysPre}" />
						<TextBlock Grid.Row="9" Style="{StaticResource FormLabel}" Text="振込先1" />
						<TextBox Grid.Row="9" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.BankAccount1}" />
						<TextBlock Grid.Row="10" Style="{StaticResource FormLabel}" Text="振込先2" />
						<TextBox Grid.Row="10" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.BankAccount2}" />
						<TextBlock Grid.Row="11" Style="{StaticResource FormLabel}" Text="振込先3" />
						<TextBox Grid.Row="11" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.BankAccount3}" />
						<TextBlock Grid.Row="12" Style="{StaticResource FormLabel}" Text="更新コメント" />
						<TextBox Grid.Row="12" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding Current.Comment}" AcceptsReturn="True" MinHeight="80" />
						<Border Grid.Row="13" Grid.ColumnSpan="2" Margin="0,16,0,0" Padding="12" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="6">
							<StackPanel>
								<TextBlock FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesignBodyLight}" Text="履歴情報" />
								<TextBlock Text="登録日" Style="{StaticResource FormLabel}" />
								<TextBlock Text="{Binding Current.VdateC}" />
								<TextBlock Text="修正日" Style="{StaticResource FormLabel}" />
								<TextBlock Text="{Binding Current.VdateU}" />
							</StackPanel>
						</Border>
					</Grid>
					</ScrollViewer>
			</materialDesign:Card>
		</Grid>
	</Grid>
</helpers:BaseWindow>
