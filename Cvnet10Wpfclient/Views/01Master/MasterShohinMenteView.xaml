<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._01Master.MasterShohinMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._01Master"
	Title="{Binding Title}"
	Width="1244" Height="900"
	d:Height="1200"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="18"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterShohinMenteViewModel />
	</helpers:BaseWindow.DataContext>

	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoOutputJsonCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>

	<Grid x:Name="grid0">
		<Grid Width="{Binding ActualWidth, ElementName=grid0, Mode=OneWay}"
			Height="{Binding ActualHeight, ElementName=grid0, Mode=OneWay}">
			<Grid.RowDefinitions>
				<RowDefinition Height="12*" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="88*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>

			<Grid Grid.Row="0" Grid.Column="0">
				<Button Width="70" Height="30"
					Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Gray"
					Command="{Binding ExitCommand}"
					Content="閉じる" />
				<Button Width="110" Height="30"
					Margin="120,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Command="{Binding DoListCommand}"
					Content="一覧取得 F5" />
				<Button Width="130" Height="30"
					Margin="240,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Command="{Binding DoOutputJsonCommand}"
					Content="JSON出力 F6" />
				<Label Height="34"
					Margin="20,49,99,0" VerticalAlignment="Top"
					Content="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
					FontSize="14" />
				<materialDesign:PackIcon Width="62" Height="70"
					Margin="370,10,0,0"
					Foreground="Blue" Kind="Package" />
			</Grid>

			<GridSplitter Grid.Row="1" Grid.ColumnSpan="3"
				Height="3"
				HorizontalAlignment="Stretch" VerticalAlignment="Center"
				Background="DarkGray" />
			<GridSplitter Grid.RowSpan="3" Grid.Column="1"
				Width="3"
				HorizontalAlignment="Center" VerticalAlignment="Stretch"
				Background="DarkGray" />

			<Grid Grid.Row="2" Grid.Column="0">
				<DataGrid x:Name="ShohinGrid"
					d:ItemsSource="{d:SampleData ItemCount=5}"
					helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" FrozenColumnCount="2" GridLinesVisibility="Horizontal"
					HorizontalGridLinesBrush="White" IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
					ItemsSource="{Binding ListData}"
					SelectedItem="{Binding Current}"
					Style="{StaticResource MaterialDesignDataGrid}"
					VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
					<DataGrid.Columns>
						<DataGridTextColumn Width="140"
							Binding="{Binding Code}"
							Header="コード" />
						<DataGridTextColumn Width="240"
							Binding="{Binding Name}"
							Header="名前" />
						<DataGridTextColumn Width="150"
							Binding="{Binding Ryaku}"
							Header="略称" />
						<DataGridTextColumn Width="150"
							Binding="{Binding Kana}"
							Header="カナ" />
						<DataGridTextColumn Width="100"
							Binding="{Binding VBrand.Mei}"
							Header="ブランド" />
					</DataGrid.Columns>
					<DataGrid.ColumnHeaderStyle>
						<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
							TargetType="DataGridColumnHeader">
							<Setter Property="Background" Value="Black" />
							<Setter Property="Foreground" Value="White" />
							<Setter Property="BorderThickness" Value="0.5" />
						</Style>
					</DataGrid.ColumnHeaderStyle>
				</DataGrid>
			</Grid>

			<Grid Grid.Row="0" Grid.Column="2">
				<Button Width="100" Height="30"
					Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Purple"
					Command="{Binding DoUpdateCommand}"
					Content="修正 F2" />
				<Button Width="100" Height="30"
					Margin="130,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Purple"
					Command="{Binding DoDeleteCommand}"
					Content="削除 F3" />
				<Button Width="100" Height="30"
					Margin="250,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
					Background="Purple"
					Command="{Binding DoInsertCommand}"
					Content="追加 F4" />
				<Label Height="40"
					Margin="383,10,0,0" VerticalAlignment="Top"
					Content="{Binding Count}"
					ContentStringFormat="{}件数={0:N0}" />
				<TextBlock Height="34"
					Margin="24,55,0,0" VerticalAlignment="Top"
					FontSize="16"
					Foreground="{DynamicResource MaterialDesignBody}"
					Text="{Binding Message}"
					TextWrapping="Wrap" />
			</Grid>

			<Grid Grid.Row="2" Grid.Column="2"
				Margin="10">
				<TabControl Style="{StaticResource MaterialDesignTabControl}">
					<TabItem>
						<TabItem.Header>
							<TextBlock Text="{Binding CurrentEdit.Id, StringFormat={}Id:{0}}" />
						</TabItem.Header>
						<ScrollViewer VerticalScrollBarVisibility="Auto">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="30*" />
									<ColumnDefinition Width="70*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Label Grid.Row="0"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="コード" />
								<TextBox Grid.Row="0" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Code}"
									TextWrapping="Wrap" />

								<Label Grid.Row="1"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="名前" />
								<TextBox Grid.Row="1" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Name}"
									TextWrapping="Wrap" />

								<Label Grid.Row="2"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="略称" />
								<TextBox Grid.Row="2" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Ryaku}"
									TextWrapping="Wrap" />

								<Label Grid.Row="3"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="カナ" />
								<TextBox Grid.Row="3" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Kana}"
									TextWrapping="Wrap" />

								<Label Grid.Row="4"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="ブランド" />
								<helpers:SearchTextBox Grid.Row="4" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectBrandCommand}"
									Text="{Binding CurrentEdit.Id_Brand, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>

								<TextBlock Grid.Row="4" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VBrand.Cd" />
											<Binding Path="CurrentEdit.VBrand.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>

								<Label Grid.Row="5"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="アイテム" />
								<helpers:SearchTextBox Grid.Row="5" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectItemCommand}"
									Text="{Binding CurrentEdit.Id_Item, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>

								<TextBlock Grid.Row="5" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VItem.Cd" />
											<Binding Path="CurrentEdit.VItem.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>

								<Label Grid.Row="6"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="メーカー" />
								<helpers:SearchTextBox Grid.Row="6" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectMakerCommand}"
									Text="{Binding CurrentEdit.Id_Maker, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>

								<TextBlock Grid.Row="6" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VMaker.Cd" />
											<Binding Path="CurrentEdit.VMaker.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>

								<Label Grid.Row="7"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="元上代" />
								<TextBox Grid.Row="7" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.TankaJodaiOrg}"
									TextWrapping="Wrap" />

								<Label Grid.Row="8"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="上代" />
								<TextBox Grid.Row="8" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.TankaJodai}"
									TextWrapping="Wrap" />

								<Label Grid.Row="9"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="原価" />
								<TextBox Grid.Row="9" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.TankaGenka}"
									TextWrapping="Wrap" />

								<Label Grid.Row="10"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="仕入単価" />
								<TextBox Grid.Row="10" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.TankaShiire}"
									TextWrapping="Wrap" />

								<Label Grid.Row="11"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="メーカー品番" />
								<TextBox Grid.Row="11" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.MakerHin}"
									TextWrapping="Wrap" />

								<Label Grid.Row="12"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="出荷日" />
								<DatePicker Grid.Row="12" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									materialDesign:HintAssist.Hint="出荷日" IsTodayHighlighted="False"
									SelectedDate="{Binding CurrentEdit.DayShukka, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

								<Label Grid.Row="13"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="納品日" />
								<DatePicker Grid.Row="13" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									materialDesign:HintAssist.Hint="納品日" IsTodayHighlighted="False"
									SelectedDate="{Binding CurrentEdit.DayNohin, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

								<Label Grid.Row="14"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="店舗投入日" />
								<DatePicker Grid.Row="14" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									materialDesign:HintAssist.Hint="店舗投入日" IsTodayHighlighted="False"
									SelectedDate="{Binding CurrentEdit.DayTento, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

								<Label Grid.Row="15"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="在庫管理" />
								<ComboBox Grid.Row="15" Grid.Column="1"
									Height="36"
									Margin="10,10,10,0" VerticalAlignment="Top"
									SelectedIndex="{Binding CurrentEdit.IsZaiko, Mode=TwoWay}">
									<ComboBoxItem Content="しない" />
									<ComboBoxItem Content="する" />
								</ComboBox>

								<Label Grid.Row="16"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="サイズ区分" />
								<helpers:SearchTextBox Grid.Row="16" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectSizeKuCommand}"
									Text="{Binding CurrentEdit.SizeKu, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>

								<Label Grid.Row="17"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="基準倉庫" />
								<helpers:SearchTextBox Grid.Row="17" Grid.Column="1"
									Width="120" Height="40"
									Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectSokoCommand}"
									Text="{Binding CurrentEdit.Id_Soko, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left">
									<helpers:SearchTextBox.Style>
										<Style TargetType="{x:Type helpers:SearchTextBox}">
											<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}" />
											<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
										</Style>
									</helpers:SearchTextBox.Style>
								</helpers:SearchTextBox>

								<TextBlock Grid.Row="17" Grid.Column="1"
									Height="36"
									Margin="150,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									TextWrapping="Wrap">
									<TextBlock.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="CurrentEdit.VSoko.Cd" />
											<Binding Path="CurrentEdit.VSoko.Mei" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>

								<Label Grid.Row="18"
									Height="36"
									Margin="15,10,0,0" VerticalAlignment="Top"
									Content="メモ" />
								<TextBox Grid.Row="18" Grid.Column="1"
									Height="60"
									Margin="10,10,10,0" VerticalAlignment="Top"
									Foreground="{DynamicResource MaterialDesignBody}"
									Text="{Binding CurrentEdit.Memo}"
									TextWrapping="Wrap" />
							</Grid>
						</ScrollViewer>
					</TabItem>
					<TabItem Header="原価リスト">
						<DataGrid x:Name="JgenkaGrid"
							Margin="10"
							d:ItemsSource="{d:SampleData ItemCount=3}"
							helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
							HorizontalGridLinesBrush="White" IsSynchronizedWithCurrentItem="True"
							ItemsSource="{Binding CurrentEdit.Jgenka}"
							Style="{StaticResource MaterialDesignDataGrid}"
							VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
							<DataGrid.Columns>
								<DataGridTextColumn Width="100"
									Binding="{Binding No}"
									Header="No" />
								<DataGridTextColumn Width="150"
									Binding="{Binding TankaGenka}"
									Header="原価" />
								<DataGridTextColumn Width="150"
									Binding="{Binding TankaShiire}"
									Header="仕入単価" />
							</DataGrid.Columns>
							<DataGrid.ColumnHeaderStyle>
								<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
									TargetType="DataGridColumnHeader">
									<Setter Property="Background" Value="Black" />
									<Setter Property="Foreground" Value="White" />
									<Setter Property="BorderThickness" Value="0.5" />
								</Style>
							</DataGrid.ColumnHeaderStyle>
						</DataGrid>
					</TabItem>
					<TabItem Header="色サイズリスト">
						<DataGrid x:Name="JcolsizGrid"
							Margin="10"
							d:ItemsSource="{d:SampleData ItemCount=5}"
							helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
							HorizontalGridLinesBrush="White" IsSynchronizedWithCurrentItem="True"
							ItemsSource="{Binding CurrentEdit.Jcolsiz}"
							SelectedItem="{Binding SelectedJcolsiz, Mode=TwoWay}"
							Style="{StaticResource MaterialDesignDataGrid}"
							VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
							<DataGrid.Columns>
								<DataGridTemplateColumn Width="130"
									Header="色検索">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<Grid Margin="2,1">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="30" />
												</Grid.ColumnDefinitions>
												<TextBox Grid.Column="0"
													Height="28"
													VerticalAlignment="Center"
													Foreground="{DynamicResource MaterialDesignBody}"
													IsReadOnly="True"
													Text="{Binding Id_Col, UpdateSourceTrigger=PropertyChanged}" />
												<Button Grid.Column="1"
													Width="26" Height="26"
													Margin="2,0,0,0" Padding="0" VerticalAlignment="Center"
													Background="{DynamicResource PrimaryButtonColor}"
													BorderThickness="0"
													Command="{Binding DataContext.DoSelectColCommand, RelativeSource={RelativeSource AncestorType=helpers:BaseWindow}}"
													CommandParameter="{Binding Id_Col}"
													Cursor="Hand" Foreground="White">
													<Button.Content>
														<materialDesign:PackIcon Width="16" Height="16"
															HorizontalAlignment="Center" VerticalAlignment="Center"
															Foreground="White" Kind="Magnify" />
													</Button.Content>
												</Button>
											</Grid>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
								<DataGridTextColumn Width="100"
									Binding="{Binding Code_Col}"
									Header="カラーCD" IsReadOnly="True" />
								<DataGridTextColumn Width="60"
									Binding="{Binding Mei_Col}"
									Header="カラー名" IsReadOnly="True" />
								<DataGridTemplateColumn Width="120"
									Header="サイズ検索">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<Grid Margin="2,1">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="30" />
												</Grid.ColumnDefinitions>
												<TextBox Grid.Column="0"
													Height="28"
													VerticalAlignment="Center"
													Foreground="{DynamicResource MaterialDesignBody}"
													IsReadOnly="True"
													Text="{Binding Id_Siz, UpdateSourceTrigger=PropertyChanged}" />
												<Button Grid.Column="1"
													Width="26" Height="26"
													Margin="2,0,0,0" Padding="0" VerticalAlignment="Center"
													Background="{DynamicResource PrimaryButtonColor}"
													BorderThickness="0"
													Command="{Binding DataContext.DoSelectSizCommand, RelativeSource={RelativeSource AncestorType=helpers:BaseWindow}}"
													CommandParameter="{Binding Id_Siz}"
													Cursor="Hand" Foreground="White">
													<Button.Content>
														<materialDesign:PackIcon Width="16" Height="16"
															HorizontalAlignment="Center" VerticalAlignment="Center"
															Foreground="White" Kind="Magnify" />
													</Button.Content>
												</Button>
											</Grid>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
								<DataGridTextColumn Width="60"
									Binding="{Binding Code_Siz}"
									Header="サイズCD" IsReadOnly="True" />
								<DataGridTextColumn Width="120"
									Binding="{Binding Mei_Siz}"
									Header="サイズ名" IsReadOnly="True" />
								<DataGridTextColumn Width="150"
									Binding="{Binding Jan1}"
									Header="JANコード1" />
								<DataGridTextColumn Width="150"
									Binding="{Binding Jan2}"
									Header="JANコード2" />
								<DataGridTextColumn Width="150"
									Binding="{Binding Jan3}"
									Header="JANコード3" />
							</DataGrid.Columns>
							<DataGrid.ColumnHeaderStyle>
								<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
									TargetType="DataGridColumnHeader">
									<Setter Property="Background" Value="Black" />
									<Setter Property="Foreground" Value="White" />
									<Setter Property="BorderThickness" Value="0.5" />
								</Style>
							</DataGrid.ColumnHeaderStyle>
						</DataGrid>
					</TabItem>
					<TabItem Header="品質リスト">
						<DataGrid x:Name="JgradeGrid"
							Margin="10"
							d:ItemsSource="{d:SampleData ItemCount=3}"
							helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
							HorizontalGridLinesBrush="White" IsSynchronizedWithCurrentItem="True"
							ItemsSource="{Binding CurrentEdit.Jgrade}"
							Style="{StaticResource MaterialDesignDataGrid}"
							VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
							<DataGrid.Columns>
								<DataGridTextColumn Width="100"
									Binding="{Binding No}"
									Header="No" />
								<DataGridTextColumn Width="200"
									Binding="{Binding Hinshitu}"
									Header="品質" />
								<DataGridTextColumn Width="100"
									Binding="{Binding Percent}"
									Header="%" />
							</DataGrid.Columns>
							<DataGrid.ColumnHeaderStyle>
								<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
									TargetType="DataGridColumnHeader">
									<Setter Property="Background" Value="Black" />
									<Setter Property="Foreground" Value="White" />
									<Setter Property="BorderThickness" Value="0.5" />
								</Style>
							</DataGrid.ColumnHeaderStyle>
						</DataGrid>
					</TabItem>
					<TabItem Header="名称リスト">
						<DataGrid x:Name="JsubGrid"
							Margin="10"
							d:ItemsSource="{d:SampleData ItemCount=3}"
							helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" AutoGenerateColumns="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
							HorizontalGridLinesBrush="White" IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
							ItemsSource="{Binding CurrentEdit.Jsub}"
							Style="{StaticResource MaterialDesignDataGrid}"
							VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
							<DataGrid.Columns>
								<DataGridTextColumn Width="100"
									Binding="{Binding Kb}"
									Header="区分" />
								<DataGridTextColumn Width="120"
									Binding="{Binding Cd}"
									Header="コード" />
								<DataGridTextColumn Width="200"
									Binding="{Binding Mei}"
									Header="名称" />
								<DataGridTextColumn Width="*"
									Binding="{Binding Kbname}"
									Header="区分名" />
							</DataGrid.Columns>
							<DataGrid.ColumnHeaderStyle>
								<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
									TargetType="DataGridColumnHeader">
									<Setter Property="Background" Value="Black" />
									<Setter Property="Foreground" Value="White" />
									<Setter Property="BorderThickness" Value="0.5" />
								</Style>
							</DataGrid.ColumnHeaderStyle>
						</DataGrid>
					</TabItem>
					<TabItem Header="詳細内容">
						<Grid Margin="10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="30*" />
								<ColumnDefinition Width="70*" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<Label Grid.Row="0"
								Height="36"
								Margin="5,5,0,0" VerticalAlignment="Top"
								Content="予備項目1" />
							<TextBox Grid.Row="0" Grid.Column="1"
								Height="36"
								Margin="10,5,10,0" VerticalAlignment="Top"
								Foreground="{DynamicResource MaterialDesignBody}"
								Text="{Binding CurrentEdit.Jdetail.Yobi1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								TextWrapping="Wrap" />

							<Label Grid.Row="1"
								Height="36"
								Margin="5,10,0,0" VerticalAlignment="Top"
								Content="予備項目2" />
							<TextBox Grid.Row="1" Grid.Column="1"
								Height="36"
								Margin="10,10,10,0" VerticalAlignment="Top"
								Foreground="{DynamicResource MaterialDesignBody}"
								Text="{Binding CurrentEdit.Jdetail.Yobi2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								TextWrapping="Wrap" />
						</Grid>
					</TabItem>
				</TabControl>
			</Grid>
		</Grid>
	</Grid>
</helpers:BaseWindow>
