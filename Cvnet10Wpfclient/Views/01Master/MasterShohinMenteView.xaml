<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._01Master.MasterShohinMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._01Master"
	Title="{Binding Title}"
	Width="1280" Height="920"
	d:Height="1200"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="16"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterShohinMenteViewModel />
	</helpers:BaseWindow.DataContext>

	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoOutputJsonCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>

	<!--  SearchTextBox 共通スタイル  -->
	<helpers:BaseWindow.Resources>
		<Style x:Key="MenteSearchTextBox"
			TargetType="{x:Type helpers:SearchTextBox}">
			<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
			<Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
			<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
		</Style>

		<!--  DataGrid ヘッダースタイル（テーマカラーベース）  -->
		<Style x:Key="MenteDataGridColumnHeader"
			BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
			TargetType="DataGridColumnHeader">
			<Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}" />
			<Setter Property="Padding" Value="12,8" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<!--  編集フォームのラベルスタイル  -->
		<Style x:Key="FormLabel"
			TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
			<Setter Property="Margin" Value="4,0,8,0" />
		</Style>

		<!--  編集フォームの TextBox スタイル  -->
		<Style x:Key="FormTextBox"
			BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
			TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.7" />
		</Style>
	</helpers:BaseWindow.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  ===== ヘッダー: ColorZone ツールバー =====  -->
		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" Mode="PrimaryMid">
			<DockPanel>
				<!--  右側: CRUD ボタン群  -->
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button Margin="4,0"
						Command="{Binding DoUpdateCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="修正 (F2)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Pencil" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="修正" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoDeleteCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="削除 (F3)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Delete" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="削除" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoInsertCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="追加 (F4)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Plus" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="追加" />
						</StackPanel>
					</Button>
					<Rectangle Width="1"
						Margin="8,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Margin="4,0"
						Command="{Binding DoOutputJsonCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="JSON出力 (F6)">
						<materialDesign:PackIcon Kind="FileExport" />
					</Button>
				</StackPanel>

				<!--  左側: タイトル + 操作  -->
				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0"
						Command="{Binding ExitCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="閉じる (Esc)">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<materialDesign:PackIcon Width="28" Height="28"
						VerticalAlignment="Center"
						Kind="Package" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
						FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
					<Rectangle Width="1"
						Margin="16,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Command="{Binding DoListCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="一覧取得 (F5)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="DatabaseSearch" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="一覧取得" />
						</StackPanel>
					</Button>
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>

		<!--  ===== メインコンテンツ =====  -->
		<Grid Grid.Row="1"
			Margin="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>

			<!--  ===== 左パネル: 一覧グリッド (Card) =====  -->
			<materialDesign:Card Grid.Column="0"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<!--  カードヘッダー: 件数 + メッセージ  -->
					<Border Grid.Row="0"
						Padding="12,8"
						Background="{DynamicResource MaterialDesignToolBarBackground}"
						CornerRadius="8,8,0,0">
						<DockPanel>
							<TextBlock VerticalAlignment="Center"
								DockPanel.Dock="Right" FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Count, StringFormat={}件数: {0:N0}}" />
							<TextBlock VerticalAlignment="Center"
								FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Message}"
								TextTrimming="CharacterEllipsis" />
						</DockPanel>
					</Border>

					<!--  DataGrid 一覧  -->
					<DataGrid x:Name="ShohinGrid"
						Grid.Row="1"
						d:ItemsSource="{d:SampleData ItemCount=5}"
						helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" materialDesign:DataGridAssist.CellPadding="12,6" materialDesign:DataGridAssist.ColumnHeaderPadding="12,8"
						AutoGenerateColumns="False" EnableRowVirtualization="True" FrozenColumnCount="2" GridLinesVisibility="Horizontal"
						HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
						IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
						ItemsSource="{Binding ListData}"
						SelectedItem="{Binding Current}"
						Style="{StaticResource MaterialDesignDataGrid}"
						VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
						<DataGrid.Columns>
							<DataGridTextColumn Width="130"
								Binding="{Binding Code}"
								Header="コード" />
							<DataGridTextColumn Width="220"
								Binding="{Binding Name}"
								Header="名前" />
							<DataGridTextColumn Width="140"
								Binding="{Binding Ryaku}"
								Header="略称" />
							<DataGridTextColumn Width="140"
								Binding="{Binding Kana}"
								Header="カナ" />
							<DataGridTextColumn Width="100"
								Binding="{Binding VBrand.Mei}"
								Header="ブランド" />
						</DataGrid.Columns>
						<DataGrid.ColumnHeaderStyle>
							<Style BasedOn="{StaticResource MenteDataGridColumnHeader}"
								TargetType="DataGridColumnHeader" />
						</DataGrid.ColumnHeaderStyle>
					</DataGrid>
				</Grid>
			</materialDesign:Card>

			<!--  スプリッタ  -->
			<GridSplitter Grid.Column="1"
				Width="6"
				Margin="3,0" HorizontalAlignment="Center" VerticalAlignment="Stretch"
				Background="Transparent" />

			<!--  ===== 右パネル: 編集エリア (Card + TabControl) =====  -->
			<materialDesign:Card Grid.Column="2"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<TabControl Style="{StaticResource MaterialDesignTabControl}">

					<!--  タブ1: 基本情報  -->
					<TabItem>
						<TabItem.Header>
							<StackPanel Orientation="Horizontal">
								<materialDesign:PackIcon Margin="0,0,6,0" VerticalAlignment="Center"
									Kind="InformationOutline" />
								<TextBlock Text="{Binding CurrentEdit.Id, StringFormat={}Id:{0}}" />
							</StackPanel>
						</TabItem.Header>
						<ScrollViewer Padding="10,10,20,20"
							VerticalScrollBarVisibility="Auto">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="110" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<!--  コード  -->
								<TextBlock Grid.Row="0"
									Style="{StaticResource FormLabel}"
									Text="コード" />
								<TextBox Grid.Row="0" Grid.Column="1"
									materialDesign:HintAssist.Hint="コード"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Code}" />

								<!--  名前  -->
								<TextBlock Grid.Row="1"
									Style="{StaticResource FormLabel}"
									Text="名前" />
								<TextBox Grid.Row="1" Grid.Column="1"
									materialDesign:HintAssist.Hint="名前"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Name}" />

								<!--  略称  -->
								<TextBlock Grid.Row="2"
									Style="{StaticResource FormLabel}"
									Text="略称" />
								<TextBox Grid.Row="2" Grid.Column="1"
									materialDesign:HintAssist.Hint="略称"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Ryaku}" />

								<!--  カナ  -->
								<TextBlock Grid.Row="3"
									Style="{StaticResource FormLabel}"
									Text="カナ" />
								<TextBox Grid.Row="3" Grid.Column="1"
									materialDesign:HintAssist.Hint="カナ"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Kana}" />

								<!--  ブランド  -->
								<TextBlock Grid.Row="4"
									Style="{StaticResource FormLabel}"
									Text="ブランド" />
								<DockPanel Grid.Row="4" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectBrandCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Brand, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VBrand.Cd" />
												<Binding Path="CurrentEdit.VBrand.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<!--  アイテム  -->
								<TextBlock Grid.Row="5"
									Style="{StaticResource FormLabel}"
									Text="アイテム" />
								<DockPanel Grid.Row="5" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectItemCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Item, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VItem.Cd" />
												<Binding Path="CurrentEdit.VItem.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<!--  メーカー  -->
								<TextBlock Grid.Row="6"
									Style="{StaticResource FormLabel}"
									Text="メーカー" />
								<DockPanel Grid.Row="6" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectMakerCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Maker, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VMaker.Cd" />
												<Binding Path="CurrentEdit.VMaker.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<!--  元上代  -->
								<TextBlock Grid.Row="7"
									Style="{StaticResource FormLabel}"
									Text="元上代" />
								<TextBox Grid.Row="7" Grid.Column="1"
									materialDesign:HintAssist.Hint="元上代"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.TankaJodaiOrg}" />

								<!--  上代  -->
								<TextBlock Grid.Row="8"
									Style="{StaticResource FormLabel}"
									Text="上代" />
								<TextBox Grid.Row="8" Grid.Column="1"
									materialDesign:HintAssist.Hint="上代"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.TankaJodai}" />

								<!--  原価  -->
								<TextBlock Grid.Row="9"
									Style="{StaticResource FormLabel}"
									Text="原価" />
								<TextBox Grid.Row="9" Grid.Column="1"
									materialDesign:HintAssist.Hint="原価"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.TankaGenka}" />

								<!--  仕入単価  -->
								<TextBlock Grid.Row="10"
									Style="{StaticResource FormLabel}"
									Text="仕入単価" />
								<TextBox Grid.Row="10" Grid.Column="1"
									materialDesign:HintAssist.Hint="仕入単価"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.TankaShiire}" />

								<!--  メーカー品番  -->
								<TextBlock Grid.Row="11"
									Style="{StaticResource FormLabel}"
									Text="メーカー品番" />
								<TextBox Grid.Row="11" Grid.Column="1"
									materialDesign:HintAssist.Hint="メーカー品番"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.MakerHin}" />

								<!--  出荷日  -->
								<TextBlock Grid.Row="12"
									Style="{StaticResource FormLabel}"
									Text="出荷日" />
								<DatePicker Grid.Row="12" Grid.Column="1"
									Margin="0,4"
									materialDesign:HintAssist.Hint="出荷日" IsTodayHighlighted="False"
									SelectedDate="{Binding CurrentEdit.DayShukka, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

								<!--  納品日  -->
								<TextBlock Grid.Row="13"
									Style="{StaticResource FormLabel}"
									Text="納品日" />
								<DatePicker Grid.Row="13" Grid.Column="1"
									Margin="0,4"
									materialDesign:HintAssist.Hint="納品日" IsTodayHighlighted="False"
									SelectedDate="{Binding CurrentEdit.DayNohin, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

								<!--  店舗投入日  -->
								<TextBlock Grid.Row="14"
									Style="{StaticResource FormLabel}"
									Text="店舗投入日" />
								<DatePicker Grid.Row="14" Grid.Column="1"
									Margin="0,4"
									materialDesign:HintAssist.Hint="店舗投入日" IsTodayHighlighted="False"
									SelectedDate="{Binding CurrentEdit.DayTento, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />

								<!--  在庫管理  -->
								<TextBlock Grid.Row="15"
									Style="{StaticResource FormLabel}"
									Text="在庫管理" />
								<ComboBox Grid.Row="15" Grid.Column="1"
									Margin="0,4"
									materialDesign:HintAssist.Hint="在庫管理"
									SelectedIndex="{Binding CurrentEdit.IsZaiko, Mode=TwoWay}"
									Style="{StaticResource MaterialDesignOutlinedComboBox}">
									<ComboBoxItem Content="しない" />
									<ComboBoxItem Content="する" />
								</ComboBox>

								<!--  サイズ区分  -->
								<TextBlock Grid.Row="16"
									Style="{StaticResource FormLabel}"
									Text="サイズ区分" />
								<helpers:SearchTextBox Grid.Row="16" Grid.Column="1"
									Width="120" Height="36"
									Margin="0,4" HorizontalAlignment="Left"
									BorderThickness="0,0,0,1"
									Command="{Binding DoSelectSizeKuCommand}"
									Style="{StaticResource MenteSearchTextBox}"
									Text="{Binding CurrentEdit.SizeKu, UpdateSourceTrigger=PropertyChanged}"
									TextHorizontalContentAlignment="Left" />

								<!--  基準倉庫  -->
								<TextBlock Grid.Row="17"
									Style="{StaticResource FormLabel}"
									Text="基準倉庫" />
								<DockPanel Grid.Row="17" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectSokoCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Soko, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VSoko.Cd" />
												<Binding Path="CurrentEdit.VSoko.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<!--  メモ  -->
								<TextBlock Grid.Row="18"
									Style="{StaticResource FormLabel}"
									Text="メモ" />
								<TextBox Grid.Row="18" Grid.Column="1"
									MinHeight="60"
									materialDesign:HintAssist.Hint="メモ" AcceptsReturn="True"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Memo}"
									TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
							</Grid>
						</ScrollViewer>
					</TabItem>

					<!--  タブ2: 原価リスト  -->
					<TabItem>
						<TabItem.Header>
							<StackPanel Orientation="Horizontal">
								<materialDesign:PackIcon Margin="0,0,6,0" VerticalAlignment="Center"
									Kind="CurrencyJpy" />
								<TextBlock Text="原価リスト" />
							</StackPanel>
						</TabItem.Header>
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>
							<StackPanel Grid.Row="0"
								Margin="8,8,8,0" HorizontalAlignment="Center"
								Orientation="Horizontal">
								<Button Margin="8,0"
									Command="{Binding DeleteJgenkaCommand}"
									Style="{StaticResource MaterialDesignOutlinedButton}">
									<StackPanel Orientation="Horizontal">
										<materialDesign:PackIcon VerticalAlignment="Center"
											Kind="Delete" />
										<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
											Text="削除" />
									</StackPanel>
								</Button>
								<Button Margin="8,0"
									Command="{Binding AddJgenkaCommand}"
									Style="{StaticResource MaterialDesignOutlinedButton}">
									<StackPanel Orientation="Horizontal">
										<materialDesign:PackIcon VerticalAlignment="Center"
											Kind="Plus" />
										<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
											Text="追加" />
									</StackPanel>
								</Button>
							</StackPanel>
							<DataGrid x:Name="JgenkaGrid"
								Grid.Row="1"
								Margin="8"
								d:ItemsSource="{d:SampleData ItemCount=3}"
								helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" materialDesign:DataGridAssist.CellPadding="12,6" materialDesign:DataGridAssist.ColumnHeaderPadding="12,8"
								AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
								HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
								IsSynchronizedWithCurrentItem="True"
								ItemsSource="{Binding CurrentEdit.Jgenka}"
								SelectedItem="{Binding SelectedJgenka, Mode=TwoWay}"
								Style="{StaticResource MaterialDesignDataGrid}"
								VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
								<DataGrid.Columns>
									<DataGridTextColumn Width="100"
										Binding="{Binding No}"
										Header="No" />
									<DataGridTextColumn Width="150"
										Binding="{Binding TankaGenka}"
										Header="原価" />
									<DataGridTextColumn Width="150"
										Binding="{Binding TankaShiire}"
										Header="仕入単価" />
								</DataGrid.Columns>
								<DataGrid.ColumnHeaderStyle>
									<Style BasedOn="{StaticResource MenteDataGridColumnHeader}"
										TargetType="DataGridColumnHeader" />
								</DataGrid.ColumnHeaderStyle>
							</DataGrid>
						</Grid>
					</TabItem>

