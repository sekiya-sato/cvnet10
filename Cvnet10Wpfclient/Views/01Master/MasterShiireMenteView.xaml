<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._01Master.MasterShiireMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._01Master"
	Title="{Binding Title}"
	Width="1244" Height="900"
	d:Height="1200"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="18"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterShiireMenteViewModel />
	</helpers:BaseWindow.DataContext>

	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoOutputJsonCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>

	<!--  SearchTextBox 共通スタイル  -->
	<helpers:BaseWindow.Resources>
		<Style x:Key="MenteSearchTextBox"
			TargetType="{x:Type helpers:SearchTextBox}">
			<Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}" />
			<Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}" />
			<Setter Property="ButtonBackground" Value="{DynamicResource SearchButtonBackgroundBrush}" />
		</Style>

		<!--  DataGrid ヘッダースタイル（テーマカラーベース）  -->
		<Style x:Key="MenteDataGridColumnHeader"
			BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
			TargetType="DataGridColumnHeader">
			<Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}" />
			<Setter Property="Padding" Value="12,8" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<!--  編集フォームのラベルスタイル  -->
		<Style x:Key="FormLabel"
			TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
			<Setter Property="Margin" Value="4,0,8,0" />
		</Style>

		<!--  編集フォームの TextBox スタイル  -->
		<Style x:Key="FormTextBox"
			BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
			TargetType="TextBox">
			<Setter Property="Margin" Value="0,4" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
			<Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.7" />
		</Style>
	</helpers:BaseWindow.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  ===== ヘッダー: ColorZone ツールバー =====  -->
		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" Mode="PrimaryMid">
			<DockPanel>
				<!--  右側: CRUD ボタン群  -->
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button Margin="4,0"
						Command="{Binding DoUpdateCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="修正 (F2)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Pencil" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="修正" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoDeleteCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="削除 (F3)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Delete" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="削除" />
						</StackPanel>
					</Button>
					<Button Margin="4,0"
						Command="{Binding DoInsertCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="追加 (F4)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Plus" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="追加" />
						</StackPanel>
					</Button>
					<Rectangle Width="1"
						Margin="8,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Margin="4,0"
						Command="{Binding DoOutputJsonCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="JSON出力 (F6)">
						<materialDesign:PackIcon Kind="FileExport" />
					</Button>
				</StackPanel>

				<!--  左側: タイトル + 操作  -->
				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0"
						Command="{Binding ExitCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="閉じる (Esc)">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<materialDesign:PackIcon Width="28" Height="28"
						VerticalAlignment="Center"
						Kind="TruckDelivery" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
						FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
					<Rectangle Width="1"
						Margin="16,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Command="{Binding DoListCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="一覧取得 (F5)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="DatabaseSearch" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="一覧取得" />
						</StackPanel>
					</Button>
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>

		<!--  ===== メインコンテンツ =====  -->
		<Grid Grid.Row="1"
			Margin="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="45*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="55*" />
			</Grid.ColumnDefinitions>

			<!--  ===== 左パネル: 一覧グリッド (Card) =====  -->
			<materialDesign:Card Grid.Column="0"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<!--  カードヘッダー: 件数 + メッセージ  -->
					<Border Grid.Row="0"
						Padding="12,8"
						Background="{DynamicResource MaterialDesignToolBarBackground}"
						CornerRadius="8,8,0,0">
						<DockPanel>
							<TextBlock VerticalAlignment="Center"
								DockPanel.Dock="Right" FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Count, StringFormat={}件数: {0:N0}}" />
							<TextBlock VerticalAlignment="Center"
								FontSize="13"
								Foreground="{DynamicResource MaterialDesignBodyLight}"
								Text="{Binding Message}"
								TextTrimming="CharacterEllipsis" />
						</DockPanel>
					</Border>

					<!--  DataGrid 一覧  -->
					<DataGrid x:Name="ShiireGrid"
						Grid.Row="1"
						d:ItemsSource="{d:SampleData ItemCount=5}"
						helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" materialDesign:DataGridAssist.CellPadding="12,6" materialDesign:DataGridAssist.ColumnHeaderPadding="12,8"
						AutoGenerateColumns="False" EnableRowVirtualization="True" FrozenColumnCount="2" GridLinesVisibility="Horizontal"
						HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
						IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
						ItemsSource="{Binding ListData}"
						SelectedItem="{Binding Current}"
						Style="{StaticResource MaterialDesignDataGrid}"
						VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
						<DataGrid.Columns>
							<DataGridTextColumn Width="140"
								Binding="{Binding Code}"
								Header="コード" />
							<DataGridTextColumn Width="240"
								Binding="{Binding Name}"
								Header="名前" />
							<DataGridTextColumn Width="150"
								Binding="{Binding Ryaku}"
								Header="略称" />
							<DataGridTextColumn Width="150"
								Binding="{Binding Kana}"
								Header="カナ" />
						</DataGrid.Columns>
						<DataGrid.ColumnHeaderStyle>
							<Style BasedOn="{StaticResource MenteDataGridColumnHeader}"
								TargetType="DataGridColumnHeader" />
						</DataGrid.ColumnHeaderStyle>
					</DataGrid>
				</Grid>
			</materialDesign:Card>

			<!--  スプリッタ  -->
			<GridSplitter Grid.Column="1"
				Width="6"
				Margin="3,0" HorizontalAlignment="Center" VerticalAlignment="Stretch"
				Background="Transparent" />

			<!--  ===== 右パネル: 編集エリア (Card + TabControl) =====  -->
			<materialDesign:Card Grid.Column="2"
				Padding="0"
				materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
				<TabControl Style="{StaticResource MaterialDesignTabControl}">

					<!--  タブ1: 基本情報  -->
					<TabItem>
						<TabItem.Header>
							<StackPanel Orientation="Horizontal">
								<materialDesign:PackIcon Margin="0,0,6,0" VerticalAlignment="Center"
									Kind="InformationOutline" />
								<TextBlock>
									<TextBlock.Text>
										<Binding Path="CurrentEdit.Id" StringFormat="Id:{0}" />
									</TextBlock.Text>
								</TextBlock>
							</StackPanel>
						</TabItem.Header>
						<ScrollViewer Padding="10,10,20,20"
							VerticalScrollBarVisibility="Auto">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="110" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<!--  コード  -->
								<TextBlock Grid.Row="0"
									Style="{StaticResource FormLabel}"
									Text="コード" />
								<TextBox Grid.Row="0" Grid.Column="1"
									materialDesign:HintAssist.Hint="コード"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Code}" />

								<!--  名前  -->
								<TextBlock Grid.Row="1"
									Style="{StaticResource FormLabel}"
									Text="名前" />
								<TextBox Grid.Row="1" Grid.Column="1"
									materialDesign:HintAssist.Hint="名前"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Name}" />

								<!--  略称  -->
								<TextBlock Grid.Row="2"
									Style="{StaticResource FormLabel}"
									Text="略称" />
								<TextBox Grid.Row="2" Grid.Column="1"
									materialDesign:HintAssist.Hint="略称"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Ryaku}" />

								<!--  カナ  -->
								<TextBlock Grid.Row="3"
									Style="{StaticResource FormLabel}"
									Text="カナ" />
								<TextBox Grid.Row="3" Grid.Column="1"
									materialDesign:HintAssist.Hint="カナ"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Kana}" />

								<!--  担当者  -->
								<TextBlock Grid.Row="4"
									Style="{StaticResource FormLabel}"
									Text="担当者" />
								<DockPanel Grid.Row="4" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectShainCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Shain, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VShain.Cd" />
												<Binding Path="CurrentEdit.VShain.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<!--  掛率  -->
								<TextBlock Grid.Row="5"
									Style="{StaticResource FormLabel}"
									Text="掛率" />
								<TextBox Grid.Row="5" Grid.Column="1"
									materialDesign:HintAssist.Hint="掛率"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.RateProper}" />

								<!--  セール掛率  -->
								<TextBlock Grid.Row="6"
									Style="{StaticResource FormLabel}"
									Text="セール掛率" />
								<TextBox Grid.Row="6" Grid.Column="1"
									materialDesign:HintAssist.Hint="セール掛率"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.RateSale}" />

								<!--  郵便番号  -->
								<TextBlock Grid.Row="7"
									Style="{StaticResource FormLabel}"
									Text="郵便番号" />
								<TextBox Grid.Row="7" Grid.Column="1"
									materialDesign:HintAssist.Hint="郵便番号"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.PostalCode}" />

								<!--  住所1  -->
								<TextBlock Grid.Row="8"
									Style="{StaticResource FormLabel}"
									Text="住所1" />
								<TextBox Grid.Row="8" Grid.Column="1"
									materialDesign:HintAssist.Hint="住所1"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Address1}" />

								<!--  住所2  -->
								<TextBlock Grid.Row="9"
									Style="{StaticResource FormLabel}"
									Text="住所2" />
								<TextBox Grid.Row="9" Grid.Column="1"
									materialDesign:HintAssist.Hint="住所2"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Address2}" />

								<!--  住所3  -->
								<TextBlock Grid.Row="10"
									Style="{StaticResource FormLabel}"
									Text="住所3" />
								<TextBox Grid.Row="10" Grid.Column="1"
									materialDesign:HintAssist.Hint="住所3"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Address3}" />

								<!--  電話番号  -->
								<TextBlock Grid.Row="11"
									Style="{StaticResource FormLabel}"
									Text="電話番号" />
								<TextBox Grid.Row="11" Grid.Column="1"
									materialDesign:HintAssist.Hint="電話番号"
									Style="{StaticResource FormTextBox}"
								Text="{Binding CurrentEdit.Tel}" />
							</Grid>
						</ScrollViewer>
					</TabItem>

					<TabItem Header="支払情報">
						<ScrollViewer VerticalScrollBarVisibility="Auto">
							<Grid Margin="10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="30*" />
									<ColumnDefinition Width="70*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<TextBlock Grid.Row="0"
									Style="{StaticResource FormLabel}"
									Text="締日1" />
								<TextBox Grid.Row="0" Grid.Column="1"
									materialDesign:HintAssist.Hint="締日1"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Shime1}" />

								<TextBlock Grid.Row="1"
									Style="{StaticResource FormLabel}"
									Text="締日2" />
								<TextBox Grid.Row="1" Grid.Column="1"
									materialDesign:HintAssist.Hint="締日2"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Shime2}" />

								<TextBlock Grid.Row="2"
									Style="{StaticResource FormLabel}"
									Text="締日3" />
								<TextBox Grid.Row="2" Grid.Column="1"
									materialDesign:HintAssist.Hint="締日3"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.Shime3}" />

								<TextBlock Grid.Row="3"
									Style="{StaticResource FormLabel}"
									Text="支払月" />
								<TextBox Grid.Row="3" Grid.Column="1"
									materialDesign:HintAssist.Hint="支払月"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.PayMonth}" />

								<TextBlock Grid.Row="4"
									Style="{StaticResource FormLabel}"
									Text="支払日" />
								<TextBox Grid.Row="4" Grid.Column="1"
									materialDesign:HintAssist.Hint="支払日"
									Style="{StaticResource FormTextBox}"
									Text="{Binding CurrentEdit.PayDay}" />

								<TextBlock Grid.Row="5"
									Style="{StaticResource FormLabel}"
									Text="支払フラグ" />
								<ComboBox Grid.Row="5" Grid.Column="1"
									Margin="0,4"
									SelectedIndex="{Binding CurrentEdit.IsPay, Mode=TwoWay}"
									Style="{StaticResource MaterialDesignOutlinedComboBox}">
									<ComboBoxItem Content="しない" />
									<ComboBoxItem Content="する" />
								</ComboBox>

								<TextBlock Grid.Row="6"
									Style="{StaticResource FormLabel}"
									Text="支払方法" />
								<DockPanel Grid.Row="6" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectPayMethodCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_PayMethod, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VPayMethod.Cd" />
												<Binding Path="CurrentEdit.VPayMethod.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>

								<TextBlock Grid.Row="7"
									Style="{StaticResource FormLabel}"
									Text="仕入先" />
								<DockPanel Grid.Row="7" Grid.Column="1"
									Margin="0,4">
									<helpers:SearchTextBox Width="120" Height="36"
										BorderThickness="0,0,0,1"
										Command="{Binding DoSelectPaysakiCommand}"
										DockPanel.Dock="Left"
										Style="{StaticResource MenteSearchTextBox}"
										Text="{Binding CurrentEdit.Id_Paysaki, UpdateSourceTrigger=PropertyChanged}"
										TextHorizontalContentAlignment="Left" />
									<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
										Foreground="{DynamicResource MaterialDesignBody}">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} {1}">
												<Binding Path="CurrentEdit.VPaysaki.Cd" />
												<Binding Path="CurrentEdit.VPaysaki.Mei" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</DockPanel>
							</Grid>
						</ScrollViewer>
					</TabItem>

					<TabItem Header="名称リスト">
						<DataGrid x:Name="JsubGrid"
							Margin="10"
							d:ItemsSource="{d:SampleData ItemCount=3}"
							helpers:DataGridSelectionBehavior.AutoScrollToSelectedItem="True" materialDesign:DataGridAssist.CellPadding="12,6" materialDesign:DataGridAssist.ColumnHeaderPadding="12,8"
							AutoGenerateColumns="False" EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
							HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
							IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
							ItemsSource="{Binding CurrentEdit.Jsub}"
							Style="{StaticResource MaterialDesignDataGrid}"
							VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
							<DataGrid.Columns>
								<DataGridTextColumn Width="100"
									Binding="{Binding Kb}"
									Header="区分" />
								<DataGridTextColumn Width="120"
									Binding="{Binding Cd}"
									Header="コード" />
								<DataGridTextColumn Width="200"
									Binding="{Binding Mei}"
									Header="名称" />
								<DataGridTextColumn Width="*"
									Binding="{Binding Kbname}"
									Header="区分名" />
							</DataGrid.Columns>
							<DataGrid.ColumnHeaderStyle>
								<Style BasedOn="{StaticResource MenteDataGridColumnHeader}"
									TargetType="DataGridColumnHeader" />
							</DataGrid.ColumnHeaderStyle>
						</DataGrid>
					</TabItem>

					<TabItem Header="詳細内容">
						<Grid Margin="10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="30*" />
								<ColumnDefinition Width="70*" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<TextBlock Grid.Row="0"
								Style="{StaticResource FormLabel}"
								Text="振込先1" />
							<TextBox Grid.Row="0" Grid.Column="1"
								materialDesign:HintAssist.Hint="振込先1"
								Style="{StaticResource FormTextBox}"
								Text="{Binding CurrentEdit.Jdetail.BankAccount1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

							<TextBlock Grid.Row="1"
								Style="{StaticResource FormLabel}"
								Text="振込先2" />
							<TextBox Grid.Row="1" Grid.Column="1"
								materialDesign:HintAssist.Hint="振込先2"
								Style="{StaticResource FormTextBox}"
								Text="{Binding CurrentEdit.Jdetail.BankAccount2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

							<TextBlock Grid.Row="2"
								Style="{StaticResource FormLabel}"
								Text="振込先3" />
							<TextBox Grid.Row="2" Grid.Column="1"
								materialDesign:HintAssist.Hint="振込先3"
								Style="{StaticResource FormTextBox}"
								Text="{Binding CurrentEdit.Jdetail.BankAccount3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

							<TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
								Margin="20"
								Foreground="{DynamicResource MaterialDesignBody}"
								TextWrapping="Wrap">
								<TextBlock.Text>
									<MultiBinding StringFormat="{}登録日={0}  修正日={1}">
										<Binding Path="CurrentEdit.VdateC" />
										<Binding Path="CurrentEdit.VdateU" />
									</MultiBinding>
								</TextBlock.Text>
							</TextBlock>
						</Grid>
					</TabItem>
				</TabControl>
			</materialDesign:Card>
		</Grid>
	</Grid>
</helpers:BaseWindow>
