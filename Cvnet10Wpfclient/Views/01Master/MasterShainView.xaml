<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._01Master.MasterShainView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:local="clr-namespace:Cvnet10Wpfclient.Views"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels"
	Title="社員マスターメンテ"
	Width="1000"
	Height="800"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterShainMenteViewModel />
	</helpers:BaseWindow.DataContext>
	<Window.InputBindings>
		<KeyBinding Key="F5"
			Command="{Binding DoListCommand}" />
		<KeyBinding Key="F6"
			Command="{Binding DoUpdateCommand}" />
		<KeyBinding Key="F7"
			Command="{Binding DoDeleteCommand}" />
		<KeyBinding Key="F8"
			Command="{Binding DoInsertCommand}" />
		<KeyBinding Key="F9"
			Command="{Binding DoPrintCommand}" />
	</Window.InputBindings>
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="4*" />
			<ColumnDefinition Width="12" />
			<ColumnDefinition Width="6*" />
		</Grid.ColumnDefinitions>

		<Grid Margin="5">
			<Grid.RowDefinitions>
				<RowDefinition Height="0.5*" />
				<RowDefinition Height="8*" />
				<RowDefinition Height="0.5*" />
			</Grid.RowDefinitions>



			<Button Grid.Row="0"
				Margin="6,0"
				HorizontalAlignment="Right"
				Command="{Binding DoListCommand}"
				Style="{DynamicResource ExecButton}" />


			<DataGrid Grid.Row="1"
				Margin="4,0"
				d:ItemsSource="{d:SampleData ItemCount=5}"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				ItemsSource="{Binding ListWorker}"
				SelectedItem="{Binding SelectedWorker}"
				SelectionMode="Single"
				Style="{DynamicResource MaterialDesignDataGrid}">
				<DataGrid.Columns>
					<DataGridTextColumn Width="4*"
						Binding="{Binding WorkerCD}"
						Header="社員CD" />
					<DataGridTextColumn Width="6*"
						Binding="{Binding Name}"
						Header="名前" />
				</DataGrid.Columns>

			</DataGrid>

			<StackPanel Grid.Row="2"
				Margin="0,0,6,0"
				HorizontalAlignment="Right"
				Orientation="Horizontal">
				<Button Margin="1,6"
					HorizontalAlignment="Right"
					BorderBrush="Black"
					BorderThickness="10"
					Command="{Binding BackListCommand}"
					Style="{DynamicResource PrevPageBtn}" />
				<Button Margin="1,6"
					HorizontalAlignment="Right"
					BorderBrush="Black"
					BorderThickness="10"
					Command="{Binding NextListCommand}"
					Style="{DynamicResource NextPageBtn}" />
			</StackPanel>

		</Grid>

		<Grid Grid.Column="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="8*" />
				<RowDefinition Height="0.5*" />
				<RowDefinition Height="0.5*" />
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
				Grid.RowSpan="2"
				Padding="8"
				Background="White"
				CornerRadius="6">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto"
							MinHeight="50" />
					</Grid.RowDefinitions>


					<TabControl Grid.Row="0"
						Grid.RowSpan="2"
						BorderThickness="1">


						<TabItem Header="基本情報(Shift+F1)">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="2*"
										MaxWidth="100" />
									<ColumnDefinition Width="4*" />
									<ColumnDefinition Width="2*"
										MaxWidth="100" />
									<ColumnDefinition Width="4*" />
								</Grid.ColumnDefinitions>

								<Grid.RowDefinitions>
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
									<RowDefinition Height="1*"
										MinHeight="40" />
								</Grid.RowDefinitions>


								<Label Grid.Row="0"
									Grid.Column="0"
									Content="社員CD" />
								<TextBox Grid.Row="0"
									Grid.Column="1"
									Grid.ColumnSpan="2"
									Text="{Binding EditWorker.WorkerCD}" />


								<Label Grid.Row="1"
									Grid.Column="0"
									Content="名前" />
								<TextBox Grid.Row="1"
									Grid.Column="1"
									Grid.ColumnSpan="2"
									Text="{Binding EditWorker.Name}" />

								<Label Grid.Row="2"
									Grid.Column="0"
									Content="カナ" />
								<TextBox Grid.Row="2"
									Grid.Column="1"
									Grid.ColumnSpan="2"
									Text="{Binding EditWorker.Furigana}" />

								<Label Grid.Row="3"
									Grid.Column="0"
									Content="写真/画像" />
								<TextBox Grid.Row="3"
									Grid.Column="1"
									Grid.ColumnSpan="3"
									Text="{Binding EditWorker.TelNo}" />

								<StackPanel Grid.Row="0"
									Grid.RowSpan="3"
									Grid.Column="3"
									Grid.ColumnSpan="2"
									Margin="4"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									Orientation="Vertical">
									<Border MaxHeight="120"
										Padding="4"
										AllowDrop="True"
										Background="#FFF"
										BorderBrush="#CCC"
										BorderThickness="1"
										CornerRadius="4">
										<Image MinHeight="100"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											Source="{Binding SourceImage}"
											Stretch="Uniform" />
									</Border>
									<Button MinWidth="100"
										Margin="0,4"
										VerticalAlignment="Bottom"
										Command="{Binding OpenFileDialogCommand}"
										Content="アップロード"
										Style="{StaticResource ImageUploadBtn}" />
								</StackPanel>


								<helpers:SearchTextBox Grid.Row="4"
									Margin="0,0,4,0"
									Command="{Binding SelShopCommand}"
									Text="{Binding EditWorker.ShopCD, UpdateSourceTrigger=PropertyChanged}" />
								<TextBox Grid.Row="4"
									Grid.Column="1"
									Grid.ColumnSpan="3"
									d:Text="店舗CD：Data"
									TextWrapping="Wrap">
									<TextBox.Text>
										<MultiBinding StringFormat="{}{0} {1}">
											<Binding Path="EditWorker.ShopCD" />
											<Binding Path="EditWorker.ShopName" />
										</MultiBinding>
									</TextBox.Text>
								</TextBox>

								<Label Grid.Row="5"
									Grid.Column="0"
									Content="部門" />
								<ComboBox Grid.Row="5"
									Grid.Column="1"
									Grid.ColumnSpan="3"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListBumon}"
									SelectedValue="{Binding EditWorker.Department}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />


								<Label Grid.Row="6"
									Grid.Column="0"
									Content="営業FLG" />
								<ComboBox Grid.Row="6"
									Grid.Column="1"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListSalesFLG}"
									SelectedValue="{Binding EditWorker.SalesFlg}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="6"
									Grid.Column="2"
									HorizontalAlignment="Center"
									Content="メールFLG" />
								<ComboBox Grid.Row="6"
									Grid.Column="3"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListMailFLG}"
									SelectedValue="{Binding EditWorker.EmailFLG}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />


								<Label Grid.Row="7"
									Grid.Column="0"
									Content="メール" />
								<TextBox Grid.Row="7"
									Grid.Column="1"
									Grid.ColumnSpan="3"
									Text="{Binding EditWorker.Mail}" />

								<Label Grid.Row="8"
									Grid.Column="0"
									Content="出力FLG" />
								<ComboBox Grid.Row="8"
									Grid.Column="1"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListOutPutFLG}"
									SelectedValue="{Binding EditWorker.OutputFLG}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="8"
									Grid.Column="2"
									HorizontalAlignment="Center"
									Content="POS区分" />
								<ComboBox Grid.Row="8"
									Grid.Column="3"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListPosCate}"
									SelectedValue="{Binding EditWorker.PosCate}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="9"
									Grid.Column="0"
									Content="備考" />
								<TextBox Grid.Row="9"
									Grid.Column="1"
									Grid.ColumnSpan="3"
									Text="{Binding EditWorker.Notes}" />

								<Label Grid.Row="10"
									Grid.Column="0"
									Content="作成日" />
								<TextBox Grid.Row="10"
									Grid.Column="1"
									IsReadOnly="True"
									Style="{DynamicResource ReadOnlyTextBox}"
									Text="{Binding EditWorker.VdateCreate, Converter={StaticResource VdateConverter}}" />

								<Label Grid.Row="10"
									Grid.Column="2"
									HorizontalAlignment="Center"
									Content="修正日" />
								<TextBox Grid.Row="10"
									Grid.Column="3"
									IsReadOnly="True"
									Style="{DynamicResource ReadOnlyTextBox}"
									Text="{Binding EditWorker.VdateUpdate, Converter={StaticResource VdateConverter}}" />


								<Label Grid.Row="11"
									Content="最終修正者" />
								<TextBox Grid.Row="11"
									Grid.Column="1"
									IsReadOnly="True"
									Style="{DynamicResource ReadOnlyTextBox}"
									Text="{Binding EditWorker.EmployeeInpCD}" />

							</Grid>
						</TabItem>
						<TabItem Header="人事情報(Shift+F2)">
							<Grid Margin="0,8,0,8">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="2*"
										MaxWidth="100" />
									<ColumnDefinition Width="8*" />
								</Grid.ColumnDefinitions>

								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Label Grid.Row="0"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="部課" />
								<ComboBox Grid.Row="0"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListBuka}"
									SelectedValue="{Binding EditWorker.SectionCD}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="1"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="役職" />
								<ComboBox Grid.Row="1"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComoListYakuShoku}"
									SelectedValue="{Binding EditWorker.PositionCD}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="2"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="就業FLG" />
								<ComboBox Grid.Row="2"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListEmplyomentFLG}"
									SelectedValue="{Binding EditWorker.EmploymentFLG}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="3"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="入社日" />
								<DatePicker Grid.Row="3"
									Grid.Column="1"
									Margin="0,8"
									Text="{Binding EditWorker.JoiningDate}" />

								<Label Grid.Row="4"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="退職日" />
								<DatePicker Grid.Row="4"
									Grid.Column="1"
									Margin="0,8"
									Text="{Binding EditWorker.RetireDate}" />

								<Label Grid.Row="5"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="有休残" />
								<TextBox Grid.Row="5"
									Grid.Column="1"
									Margin="0,8"
									Text="{Binding EditWorker.VacationRemaining}" />

								<Label Grid.Row="6"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="特休残" />
								<TextBox Grid.Row="6"
									Grid.Column="1"
									Margin="0,8"
									Text="{Binding EditWorker.SpecHolidayRemain}" />

								<Label Grid.Row="7"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="給与区分" />
								<ComboBox Grid.Row="7"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListSalaryCate}"
									SelectedValue="{Binding EditWorker.SalaryCate}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />


								<Label Grid.Row="8"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="給与給額" />
								<TextBox Grid.Row="8"
									Grid.Column="1"
									Margin="0,8"
									Text="{Binding EditWorker.SalaryAmount}" />

								<Label Grid.Row="9"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="交通費区分" />
								<ComboBox Grid.Row="9"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListTransFeeCate}"
									SelectedValue="{Binding EditWorker.TransExpCate}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="10"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="交通費給額" />
								<TextBox Grid.Row="10"
									Grid.Column="1"
									Margin="0,8"
									Text="{Binding EditWorker.TransExpAmount}" />
							</Grid>


						</TabItem>
						<TabItem Header="拡張情報(Shift+F3)">
							<Grid Margin="0,8,0,8">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="2*"
										MaxWidth="100" />
									<ColumnDefinition Width="8*" />
								</Grid.ColumnDefinitions>

								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Label Grid.Row="0"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="社員分類01" />
								<ComboBox Grid.Row="0"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListName1}"
									SelectedValue="{Binding EditWorker.NameCD01}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="1"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="社員分類02" />
								<ComboBox Grid.Row="1"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListName2}"
									SelectedValue="{Binding EditWorker.NameCD02}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="2"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="社員分類03" />
								<ComboBox Grid.Row="2"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListName3}"
									SelectedValue="{Binding EditWorker.NameCD03}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="3"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="社員分類04" />
								<ComboBox Grid.Row="3"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListName4}"
									SelectedValue="{Binding EditWorker.NameCD04}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />

								<Label Grid.Row="4"
									Margin="0,8"
									VerticalAlignment="Center"
									Content="社員分類05" />
								<ComboBox Grid.Row="4"
									Grid.Column="1"
									Margin="0,8"
									DisplayMemberPath="Value"
									ItemsSource="{Binding ComboListName5}"
									SelectedValue="{Binding EditWorker.NameCD05}"
									SelectedValuePath="Key"
									Style="{StaticResource SearchableComboBox1}" />


							</Grid>
						</TabItem>



					</TabControl>


					<Grid Grid.Row="1">
						<Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition Width="12" />
							<ColumnDefinition />
							<ColumnDefinition Width="12" />
							<ColumnDefinition />
							<ColumnDefinition Width="12" />
							<ColumnDefinition />
						</Grid.ColumnDefinitions>

						<Button Command="{Binding DoInsertCommand}"
							Style="{DynamicResource AddIconBtn}" />
						<Button Grid.Column="2"
							Command="{Binding DoUpdateCommand}"
							Style="{DynamicResource UpdateIconBtn}" />
						<Button Grid.Column="4"
							Command="{Binding DoDeleteCommand}"
							Style="{DynamicResource DeleteIconBtn}" />
						<Button Grid.Column="6"
							Command="{Binding DoPrintCommand}"
							Style="{DynamicResource PrintIconBtn}" />
					</Grid>
				</Grid>
			</Border>

			<Button Grid.Row="2"
				Margin="4"
				HorizontalAlignment="Right"
				Command="{Binding ExitCommand}"
				IsCancel="True"
				Style="{DynamicResource BackBtn}" />
		</Grid>
	</Grid>
</helpers:BaseWindow>
