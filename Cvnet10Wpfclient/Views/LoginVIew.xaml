<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views.LoginView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:local="clr-namespace:Cvnet10Wpfclient.Views"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels"
	Title="ログイン"
	Width="500"
	Height="370"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FocusManager.FocusedElement="{Binding ElementName=LoginIdTextBox}"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:LoginViewModel />
	</helpers:BaseWindow.DataContext>
	<TabControl>
		<TabItem Height="0"
			d:Header="Login"
			d:Height="40"
			d:Visibility="Visible">
			<TabItem.Style>
				<Style TargetType="TabItem">
					<Setter Property="Visibility" Value="Visible" />
					<Setter Property="IsSelected" Value="True" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsVisibleLoginTab}"
							Value="False">
							<Setter Property="Visibility" Value="Hidden" />
							<Setter Property="IsSelected" Value="False" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</TabItem.Style>
			<Grid>
				<Border Padding="40">
					<StackPanel VerticalAlignment="Center">

						<TextBlock Margin="0,0,0,30"
							HorizontalAlignment="Center"
							FontWeight="Bold"
							Style="{StaticResource MaterialDesignHeadline4TextBlock}"
							Text="SYSTEM LOGIN" />
						<TextBox x:Name="LoginIdTextBox"
							Margin="0,0,0,20"
							helpers:FocusHelper.IsEnterToNext="True"
							materialDesign:HintAssist.Foreground="{DynamicResource MaterialDesignBody}"
							materialDesign:HintAssist.Hint="ログインIDを入力してください"
							materialDesign:TextFieldAssist.HasClearButton="True"
							CaretBrush="{DynamicResource MaterialDesignBody}"
							FontSize="16"
							Style="{StaticResource MaterialDesignFloatingHintTextBox}"
							Text="{Binding LoginId, UpdateSourceTrigger=PropertyChanged}" />

						<PasswordBox Margin="0,0,0,30"
							helpers:PasswordBoxAssistant.BindPassword="True"
							helpers:PasswordBoxAssistant.BoundPassword="{Binding LoginPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							materialDesign:HintAssist.Foreground="{DynamicResource MaterialDesignBody}"
							materialDesign:HintAssist.Hint="パスワードを入力してください"
							CaretBrush="{DynamicResource color2}"
							FontSize="16"
							Foreground="{DynamicResource MaterialDesignBody2}"
							Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" />

						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<Button Grid.Column="0"
								Margin="0,0,10,0"
								Command="{Binding LoginCommand}"
								Content="OK (Enter)"
								IsDefault="True" />

							<Button Grid.Column="1"
								Margin="10,0,0,0"
								Command="{Binding ExitCommand}"
								Content="キャンセル (ESC)"
								IsCancel="True" />
						</Grid>

					</StackPanel>
				</Border>
			</Grid>
		</TabItem>
		<TabItem Height="0"
			d:Header="Refresh"
			d:Height="40"
			d:Visibility="Visible">
			<TabItem.Style>
				<Style TargetType="TabItem">
					<Setter Property="Visibility" Value="Hidden" />
					<Setter Property="IsSelected" Value="False" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsVisibleLoginTab}"
							Value="False">
							<Setter Property="Visibility" Value="Visible" />
							<Setter Property="IsSelected" Value="True" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</TabItem.Style>
			<StackPanel VerticalAlignment="Center">
				<TextBlock Margin="0,0,0,30"
					HorizontalAlignment="Center"
					FontWeight="Bold"
					Style="{StaticResource MaterialDesignHeadline4TextBlock}"
					Text="LOGIN Refresh" />
                <TextBlock Margin="20"
					HorizontalAlignment="Center"
					FontWeight="Bold"
					Style="{StaticResource MaterialDesignBody1TextBlock}"
					Text="現在の接続トークンを使ってリフレッシュを行います" />
                <Button Margin="40,0,40,0"
					Command="{Binding RefreshCommand}"
					Content="リフレッシュ"
					IsDefault="True" />
                <Button Margin="50,20,50,0"
					Command="{Binding ExitCommand}"
					Content="キャンセル(ESC)"
					IsDefault="True" />
            </StackPanel>

		</TabItem>
	</TabControl>
</helpers:BaseWindow>
